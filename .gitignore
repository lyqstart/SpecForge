# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# SpecForge project runtime (Plugin auto-generated)
specforge/

# SpecForge v1.1 runtime data (gitignored per directory-layout)
.specforge/logs/
.specforge/cas/
.specforge/runtime/
.specforge/archive/
.specforge/sessions/

# Temporary / debug artifacts
test_log/
.backup/
test_output.txt
test-output.txt
test-results.txt
.tmp/
.kiro.zip
*.log

# Kiro PBT runtime state (written to spec dirs by update_pbt_status /
