{
  "schema_version": "1.0",
  "id": "bugfix_spec",
  "displayName": "Bugfix Spec",
  "intent": "Structured bug fix workflow with systematic debugging and TDD approach",
  "intentKeywords": [
    "bug",
    "bugfix",
    "缺陷",
    "修复",
    "fix",
    "缺陷修复",
    "hotfix",
    "patch"
  ],
  "stateMachine": {
    "schema_version": "1.0",
    "initial": "intake",
    "states": {
      "intake": {
        "schema_version": "1.0",
        "agent": "",
        "skills": [],
        "produces": "intake.md",
        "gate": null,
        "next": "bugfix_analysis",
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "bugfix_analysis": {
        "schema_version": "1.0",
        "agent": "sf-requirements",
        "skills": ["superpowers-systematic-debugging"],
        "produces": "bugfix.md",
        "gate": null,
        "next": "bugfix_gate",
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "bugfix_gate": {
        "schema_version": "1.0",
        "agent": "",
        "skills": [],
        "produces": null,
        "gate": {
          "schema_version": "1.0",
          "type": "composite",
          "id": "bugfix_gate",
          "name": "Bugfix Gate",
          "mode": "sequential",
          "failPolicy": "fail_fast",
          "children": [
            {
              "schema_version": "1.0",
              "type": "simple",
              "id": "bugfix_doc_lint",
              "name": "Bugfix Doc Lint"
            },
            {
              "schema_version": "1.0",
              "type": "simple",
              "id": "bugfix_quality",
              "name": "Bugfix Quality Gate"
            }
          ]
        },
        "next": { "pass": "fix_design", "fail": "bugfix_analysis" },
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "fix_design": {
        "schema_version": "1.0",
        "agent": "sf-design",
        "skills": [],
        "produces": "design.md",
        "gate": null,
        "next": "design_gate",
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "design_gate": {
        "schema_version": "1.0",
        "agent": "",
        "skills": [],
        "produces": null,
        "gate": {
          "schema_version": "1.0",
          "type": "simple",
          "id": "design_gate",
          "name": "Design Gate"
        },
        "next": { "pass": "tasks", "fail": "fix_design" },
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "tasks": {
        "schema_version": "1.0",
        "agent": "sf-task-planner",
        "skills": ["superpowers-writing-plans"],
        "produces": "tasks.md",
        "gate": null,
        "next": "tasks_gate",
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "tasks_gate": {
        "schema_version": "1.0",
        "agent": "",
        "skills": [],
        "produces": null,
        "gate": {
          "schema_version": "1.0",
          "type": "simple",
          "id": "tasks_gate",
          "name": "Tasks Gate"
        },
        "next": { "pass": "development", "fail": "tasks" },
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "development": {
        "schema_version": "1.0",
        "agent": "sf-executor",
        "skills": ["superpowers-tdd"],
        "produces": null,
        "gate": null,
        "next": "verification",
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "verification": {
        "schema_version": "1.0",
        "agent": "sf-verifier",
        "skills": ["superpowers-verification-before-completion"],
        "produces": "verification_report",
        "gate": null,
        "next": "verification_gate",
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "verification_gate": {
        "schema_version": "1.0",
        "agent": "",
        "skills": [],
        "produces": null,
        "gate": {
          "schema_version": "1.0",
          "type": "simple",
          "id": "verification_gate",
          "name": "Verification Gate"
        },
        "next": { "pass": "completed", "fail": "verification" },
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "completed": {
        "schema_version": "1.0",
        "agent": "",
        "skills": [],
        "produces": null,
        "gate": null
      },
      "blocked": {
        "schema_version": "1.0",
        "agent": "",
        "skills": [],
        "produces": null,
        "gate": null
      }
    }
  },
  "artifacts": [
    { "name": "intake", "path": "specforge/specs/{workItemId}/intake.md", "required": true },
    { "name": "bugfix", "path": "specforge/specs/{workItemId}/bugfix.md", "required": true },
    { "name": "design", "path": "specforge/specs/{workItemId}/design.md", "required": true },
    { "name": "tasks", "path": "specforge/specs/{workItemId}/tasks.md", "required": true },
    { "name": "verification_report", "path": "specforge/specs/{workItemId}/verification_report.md", "required": false }
  ]
}
