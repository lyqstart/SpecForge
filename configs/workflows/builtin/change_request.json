{
  "schema_version": "1.0",
  "id": "change_request",
  "displayName": "Change Request",
  "intent": "Change request with impact analysis, design delta, and full review process",
  "intentKeywords": [
    "change request",
    "变更",
    "变更请求",
    "impact",
    "影响分析",
    "change",
    "modification",
    "alteration"
  ],
  "stateMachine": {
    "schema_version": "1.0",
    "initial": "intake",
    "states": {
      "intake": {
        "schema_version": "1.0",
        "agent": "",
        "skills": [],
        "produces": "intake.md",
        "gate": null,
        "next": "impact_analysis",
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "impact_analysis": {
        "schema_version": "1.0",
        "agent": "sf-requirements",
        "skills": [],
        "produces": "impact_analysis.md",
        "gate": null,
        "next": "impact_analysis_gate",
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "impact_analysis_gate": {
        "schema_version": "1.0",
        "agent": "",
        "skills": [],
        "produces": null,
        "gate": {
          "schema_version": "1.0",
          "type": "simple",
          "id": "impact_analysis_gate",
          "name": "Impact Analysis Gate"
        },
        "next": { "pass": "design_delta", "fail": "impact_analysis" },
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "design_delta": {
        "schema_version": "1.0",
        "agent": "sf-design",
        "skills": [],
        "produces": "design_delta.md",
        "gate": null,
        "next": "design_gate",
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "design_gate": {
        "schema_version": "1.0",
        "agent": "",
        "skills": [],
        "produces": null,
        "gate": {
          "schema_version": "1.0",
          "type": "simple",
          "id": "design_gate",
          "name": "Design Gate"
        },
        "next": { "pass": "tasks", "fail": "design_delta" },
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "tasks": {
        "schema_version": "1.0",
        "agent": "sf-task-planner",
        "skills": ["superpowers-writing-plans"],
        "produces": "tasks.md",
        "gate": null,
        "next": "tasks_gate",
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "tasks_gate": {
        "schema_version": "1.0",
        "agent": "",
        "skills": [],
        "produces": null,
        "gate": {
          "schema_version": "1.0",
          "type": "simple",
          "id": "tasks_gate",
          "name": "Tasks Gate"
        },
        "next": { "pass": "development", "fail": "tasks" },
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "development": {
        "schema_version": "1.0",
        "agent": "sf-executor",
        "skills": ["superpowers-subagent-driven-development"],
        "produces": null,
        "gate": null,
        "next": "review",
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "review": {
        "schema_version": "1.0",
        "agent": "sf-reviewer",
        "skills": ["superpowers-code-review"],
        "produces": null,
        "gate": null,
        "next": "verification",
        "retry": { "maxAttempts": 2, "onExhausted": "blocked" }
      },
      "verification": {
        "schema_version": "1.0",
        "agent": "sf-verifier",
        "skills": ["superpowers-verification-before-completion"],
        "produces": "verification_report",
        "gate": null,
        "next": "verification_gate",
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "verification_gate": {
        "schema_version": "1.0",
        "agent": "",
        "skills": [],
        "produces": null,
        "gate": {
          "schema_version": "1.0",
          "type": "simple",
          "id": "verification_gate",
          "name": "Verification Gate"
        },
        "next": { "pass": "completed", "fail": "verification" },
        "retry": { "maxAttempts": 3, "onExhausted": "blocked" }
      },
      "completed": {
        "schema_version": "1.0",
        "agent": "",
        "skills": [],
        "produces": null,
        "gate": null
      },
      "blocked": {
        "schema_version": "1.0",
        "agent": "",
        "skills": [],
        "produces": null,
        "gate": null
      }
    }
  },
  "artifacts": [
    { "name": "intake", "path": "specforge/specs/{workItemId}/intake.md", "required": true },
    { "name": "impact_analysis", "path": "specforge/specs/{workItemId}/impact_analysis.md", "required": true },
    { "name": "design_delta", "path": "specforge/specs/{workItemId}/design_delta.md", "required": true },
    { "name": "tasks", "path": "specforge/specs/{workItemId}/tasks.md", "required": true },
    { "name": "verification_report", "path": "specforge/specs/{workItemId}/verification_report.md", "required": false }
  ]
}
