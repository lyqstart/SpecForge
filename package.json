{
  "name": "specforge",
  "version": "6.0.0-dev",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun scripts/render-workflow-docs.ts && bun run --filter './packages/*' build",
    "test": "bun run --filter './packages/*' test",
    "lint": "bun scripts/render-workflow-docs.ts --check && bun run --filter './packages/*' lint",
    "clean": "bun run --filter './packages/*' clean",
    "render-workflows": "bun scripts/render-workflow-docs.ts",
    "check-workflows": "bun scripts/render-workflow-docs.ts --check"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "proper-lockfile": "^4.1.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "schema_version": "1.0"
}
