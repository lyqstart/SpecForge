3:   private addPrefixRoute(method: string, prefix: string, handler: RouteHandler): void {\n214:     this.prefixRoutes.push({ prefix, method, handler });\n215:   }\n216: \n217:   private matchRoute(method: string, pathname: string): { handler: RouteHandler; match: RouteMatch } | null {\n218:     // 1. Try exact match\n219:     const entries = this.exactRoutes.get(pathname);\n220:     if (entries) {\n221:       for (const entry of entries) {\n222:         if (entry.method === method || entry.method === '*') {\n223:           return { handler: entry.handler, match: { pathname, params: {} } };\n224:         }\n225:       }\n226:     }\n227: \n228:     // 2. Try prefix match\n229:     for (const entry of this.prefixRoutes) {\n230:       if (pathname.startsWith(entry.prefix)) {\n231:         if (entry.method === method || entry.method === '*') {\n232:           const wildcard = pathname.substring(entry.prefix.length);\n233:           return {\n234:             handler: entry.handler,\n235:             match: { pathname, params: { wildcard } },\n236:           };\n237:         }\n238:       }\n239:     }\n240: \n241:     return null;\n242:   }\n243: \n244:   // ── Request Handling ──\n245: \n246:   private handleRequest(req: http.IncomingMessage, res: http.ServerResponse): void {\n247:     const chunks: Buffer[] = [];\n248: \n249:     req.on('data', (chunk: Buffer | string) => {\n250:       chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(chunk));\n251:     });\n252: \n253:     req.on('end', () => {\n254:       const body = Buffer.concat(chunks);\n255:       this.handleRequestWithBody(req, res, body);\n256:     });\n257: \n258:     req.on('error', () => {\n259:       this.sendJsonResponse(res, 500, this.errorBody('INTERNAL_ERROR', 'Internal Server Error'));\n260:     });\n261:   }\n262: \n263:   private handleRequestWithBody(req: http.IncomingMessage, res: http.ServerResponse, rawBody: Buffer): void {\n264:     try {\n265:       const method = req.method ?? 'GET';\n266:       const pathname = this.safeGetPathname(req);\n267: \n268:       // Check payload size\n269:       const maxSize = this.config.getMaxPayloadSize();\n270:       if (rawBody.length > maxSize) {\n271:         this.handleOversizedPayload(req, res, rawBody, maxSize);\n272:         return;\n273:       }\n274: \n275:       // Handle CORS preflight (no auth needed)\n276:       if (method === 'OPTIONS') {\n277:         this.writeCorsPreflight(res);\n278:         return;\n279:       }\n280: \n281:       // Auth check (skip for public endpoints)\n282:       if (!this.isPublicEndpoint(pathname)) {\n283:         const authResult = this.checkAuth(req);\n284:         if (authResult) {\n285:           this.sendJsonResponse(res, authResult.statusCode, this.errorBody(authResult.code, authResult.message));\n286:           return;\n287:         }\n288:       }\n289: \n290:       // Parse JSON body for methods that may carry a body\n291:       const bodyString = rawBody.toString('utf-8');\n292:       if (rawBody.length > 0 && (method === 'POST' || method === 'PUT' || method === 'PATCH')) {\n293:         const contentType = req.headers['content-type'] ?? '';\n294:         if (contentType.includes('application/json')) {\n295:           try {\n296:             JSON.parse(bodyString); // validate JSON\n297:           } catch {\n298:             this.sendJsonResponse(res, 400, this.errorBody('INVALID_JSON', 'Invalid JSON in request body'));\n299:             return;\n300:           }\n301:         }\n302:       }\n303: \n304:       // Route matching\n305:       const matched = this.matchRoute(method, pathname);\n306:       if (!matched) {\n307:         this.sendJsonResponse(res, 404, this.errorBody('NOT_FOUND', `Route ${method} ${pathname} not found`));\n308:         return;\n309:       }\n310: \n311:       // Execute handler\n312:       const result = matched.handler(req, res, bodyString, matched.match);\n313:       if (result instanceof Promise) {\n314:         result.catch((err: unknown) => {\n315:           this.handleHandlerError(res, err);\n316:         });\n317:       }\n318:     } catch (err: unknown) {\n319:       this.handleHandlerError(res, err);\n320:     }\n321:   }\n322: \n323:   private safeGetPathname(req: http.IncomingMessage): string {\n324:     try {\n325:       return new URL(req.url ?? '/', `http://localhost:${this.port ?? 0}`).pathname;\n326:     } catch {\n327:       return '/';\n328:     }\n329:   }\n330: \n331:   private isPublicEndpoint(pathname: string): boolean {\n332:     // Public endpoints: /health, /api/v1/healthz\n333:     return pathname === '/health' || pathname === '/api/v1/healthz';\n334:   }\n335: \n336:   // ── Auth ──\n337: \n338:   private checkAuth(req: http.IncomingMessage): { statusCode: number; code: string; message: string } | null {\n339:     const authHeader = req.headers.authorization;\n340: \n341:     if (!authHeader || !authHeader.startsWith('Bearer ')) {\n342:       this.logPermissionDenied(req, 'Missing or invalid Authorization header');\n343:       return { statusCode: 401, code: 'UNAUTHORIZED', message: 'Unauthorized' };\n344:     }\n345: \n346:     const token = authHeader.substring(7);\n347: \n348:     if (!this.token) {\n349:       this.logPermissionDenied(req, 'Handshake file not found - server not initialized');\n350:       return { statusCode: 401, code: 'UNAUTHORIZED', message: 'Unauthorized' };\n351:     }\n352: \n353:     if (token !== this.token) {\n354:       this.logPermissionDenied(req, 'Invalid token');\n355:       return { statusCode: 401, code: 'UNAUTHORIZED', message: 'Unauthorized' };\n356:     }\n357: \n358:     return null;\n359:   }\n360: \n361:   private logPermissionDenied(req: http.IncomingMessage, reason: string): void {\n362:     const event: Event = {\n363:       eventId: this.generateEventId(),\n364:       ts: Date.now(),\n365:       projectId: '',\n366:       action: 'permission.denied',\n367:       payload: {\n368:         method: req.method,\n369:         path: req.url,\n370:         reason,\n371:         clientIp: req.socket.remoteAddress ?? 'unknown',\n372:       },\n373:       metadata: {\n374:         schemaVersion: '1.0',\n375:         source: 'daemon',\n376:       },\n377:     };\n378: \n379:     if (this.eventBus) {\n380:       this.eventBus.publish(event);\n381:     }\n382: \n383:     console.warn(`[AUTH] Permission denied: ${reason} - ${req.method} ${req.url}`);\n384:   }\n385: \n386:   // ── Payload Handling ──\n387: \n388:   private handleOversizedPayload(req: http.IncomingMessage, res: http.ServerResponse, body: Buffer, maxSize: number): void {\n389:     console.warn(`[PAYLOAD] Payload size ${body.length} bytes exceeds limit ${maxSize} bytes`);\n390: \n391:     this.cas.store(body).then((casReference) => {\n392:       console.log(`[PAYLOAD] Stored large payload in CAS: ${casReference.reference}`);\n393: \n394:       res.writeHead(413, { 'Content-Type': 'application/json' });\n395:       res.end(JSON.stringify({\n396:         error: 'Payload Too Large',\n397:         reason: `Payload size ${body.length} bytes exceeds limit of ${maxSize} bytes`,\n398:         casReference,\n399:       }));\n400:     }).catch((error: unknown) => {\n401:       console.error('[PAYLOAD] Failed to store payload in CAS:', error);\n402:       res.writeHead(500, { 'Content-Type': 'application/json' });\n403:       res.end(JSON.stringify({\n404:         error: 'Internal Server Error',\n405:         reason: 'Failed to store large payload in CAS',\n406:       }));\n407:     });\n408:   }\n409: \n410:   // ── Response Helpers ──\n411: \n412:   private sendJsonResponse(res: http.ServerResponse, statusCode: number, data: unknown): void {\n413:     const headers: Record<string, string> = {\n414:       'Content-Type': 'application/json',\n415:       'Access-Control-Allow-Origin': '*',\n416:     };\n417:     res.writeHead(statusCode, headers);\n418:     res.end(JSON.stringify(data));\n419:   }\n420: \n421:   private writeCorsPreflight(res: http.ServerResponse): void {\n422:     res.writeHead(204, {\n423:       'Access-Control-Allow-Origin': '*',\n424:       'Access-Control-Allow-Methods': 'GET, POST, PUT, DELETE, PATCH, OPTIONS',\n425:       'Access-Control-Allow-Headers': 'Content-Type, Authorization',\n426:       'Access-Control-Max-Age': '86400',\n427:     });\n428:     res.end();\n429:   }\n430: \n431:   private errorBody(code: string, message: string, details?: unknown): Record<string, unknown> {\n432:     const error: Record<string, unknown> = { code, message };\n433:     if (details !== undefined) {\n434:       error['details'] = details;\n435:     }\n436:     return {\n437:       success: false,\n438:       error,\n439:       requestId: this.generateRequestId(),\n440:       timestamp: Date.now(),\n441:     };\n442:   }\n443: \n444:   private successBody<T>(data: T): Record<string, unknown> {\n445:     return {\n446:       success: true,\n447:       data,\n448:       requestId: this.generateRequestId(),\n449:       timestamp: Date.now(),\n450:     };\n451:   }\n452: \n453:   // ── Global Error Handling ──\n454: \n455:   private installGlobalErrorHandlers(): void {\n456:     this.boundUncaughtHandler = (err: Error) => {\n457:       console.error('[FATAL] uncaughtException:', err);\n458:       this.sendFatalErrorToSse(err);\n459:     };\n460:     this.boundUnhandledRejectionHandler = (reason: unknown) => {\n461:       console.error('[FATAL] unhandledRejection:', reason);\n462:       this.sendFatalErrorToSse(\n463:         reason instanceof Error ? reason : new Error(String(reason)),\n464:       );\n465:     };\n466:     process.on('uncaughtException', this.boundUncaughtHandler);\n467:     process.on('unhandledRejection', this.boundUnhandledRejectionHandler);\n468:   }\n469: \n470:   private uninstallGlobalErrorHandlers(): void {\n471:     if (this.boundUncaughtHandler) {\n472:       process.removeListener('uncaughtException', this.boundUncaughtHandler);\n473:       this.boundUncaughtHandler = null;\n474:     }\n475:     if (this.boundUnhandledRejectionHandler) {\n476:       process.removeListener('unhandledRejection', this.boundUnhandledRejectionHandler);\n477:       this.boundUnhandledRejectionHandler = null;\n478:     }\n479:   }\n480: \n481:   private sendFatalErrorToSse(err: Error): void {\n482:     const event: Event = {\n483:       eventId: this.generateEventId(),\n484:       ts: Date.now(),\n485:       projectId: '',\n486:       action: 'server.fatal_error',\n487:       payload: {\n488:         message: err.message,\n489:         stack: err.stack,\n490:       },\n491:       metadata: {\n492:         schemaVersion: '1.0',\n493:         source: 'daemon',\n494:       },\n495:     };\n496: \n497:     for (const [id, clientRes] of this.sseClients) {\n498:       try {\n499:         clientRes.write(`data: ${JSON.stringify(event)}\\n\\n`);\n500:       } catch {\n501:         this.sseClients.delete(id);\n502:       }\n503:     }\n504:   }\n505: \n506:   private handleHandlerError(res: http.ServerResponse, err: unknown): void {\n507:     if (err instanceof DaemonError) {\n508:       this.sendJsonResponse(res, err.statusCode, this.errorBody(err.code, err.message, err.details));\n509:     } else if (err instanceof Error) {\n510:       this.sendJsonResponse(res, 500, this.errorBody('INTERNAL_ERROR', err.message));\n511:     } else {\n512:       this.sendJsonResponse(res, 500, this.errorBody('INTERNAL_ERROR', 'Internal Server Error'));\n513:     }\n514:   }\n515: \n516:   // ── SSE ──\n517: \n518:   private handleSSE(req: http.IncomingMessage, res: http.ServerResponse): void {\n519:     const clientId = this.generateEventId();\n520: \n521:     // SSE headers\n522:     res.writeHead(200, {\n523:       'Content-Type': 'text/event-stream',\n524:       'Cache-Control': 'no-cache',\n525:       'Connection': 'keep-alive',\n526:       'Access-Control-Allow-Origin': '*',\n527:     });\n528: \n529:     // Send initial connected event\n530:     res.write(`data: ${JSON.stringify({ type: 'connected', clientId })}\\n\\n`);\n531: \n532:     // Add to client list\n533:     this.sseClients.set(clientId, res);\n534: \n535:     // Subscribe to EventBus if not already subscribed\n536:     this.ensureSseSubscription();\n537: \n538:     // Start heartbeat if not already running\n539:     this.ensureHeartbeat();\n540: \n541:     // Handle client disconnect\n542:     req.on('close', () => {\n543:       this.sseClients.delete(clientId);\n544:       console.log(`[SSE] Client ${clientId} disconnected (${this.sseClients.size} remaining)`);\n545: \n546:       if (this.sseClients.size === 0) {\n547:         this.removeSseSubscription();\n548:         this.stopHeartbeat();\n549:       }\n550:     });\n551: \n552:     console.log(`[SSE] Client ${clientId} connected (${this.sseClients.size} total)`);\n553:   }\n554: \n555:   private ensureSseSubscription(): void {\n556:     if (this.sseSubscription || !this.eventBus) {\n557:       return;\n558:     }\n559: \n560:     const handler = (event: Event): void => {\n561:       for (const [id, clientRes] of this.sseClients) {\n562:         try {\n563:           clientRes.write(`data: ${JSON.stringify(event)}\\n\\n`);\n564:         } catch {\n565:           // Client disconnected, remove from list\n566:           this.sseClients.delete(id);\n567:         }\n568:       }\n569:     };\n570: \n571:     const subscription = this.eventBus.subscribe('*', handler);\n572:     this.sseSubscription = {\n573:       topic: '*',\n574:       handler,\n575:       unsubscribe: () => this.eventBus!.unsubscribe(subscription),\n576:     };\n577: \n578:     console.log('[SSE] Subscribed to EventBus');\n579:   }\n580: \n581:   private removeSseSubscription(): void {\n582:     if (this.sseSubscription) {\n583:       this.sseSubscription.unsubscribe();\n584:       this.sseSubscription = null;\n585:       console.log('[SSE] Unsubscribed from EventBus');\n586:     }\n587:   }\n588: \n589:   private ensureHeartbeat(): void {\n590:     if (this.heartbeatTimer) {\n591:       return;\n592:     }\n593: \n594:     this.heartbeatTimer = setInterval(() => {\n595:       for (const [id, clientRes] of this.sseClients) {\n596:         try {\n597:           clientRes.write(':heartbeat\\n\\n');\n598:         } catch {\n599:           this.sseClients.delete(id);\n600:         }\n601:       }\n602:     }, this.SSE_HEARTBEAT_INTERVAL);\n603: \n604:     // Allow Node to exit even if the heartbeat timer is still active\n605:     if (this.heartbeatTimer && typeof this.heartbeatTimer === 'object') {\n606:       this.heartbeatTimer.unref();\n607:     }\n608:   }\n609: \n610:   private stopHeartbeat(): void {\n611:     if (this.heartbeatTimer !== null) {\n612:       clearInterval(this.heartbeatTimer);\n613:       this.heartbeatTimer = null;\n614:     }\n615:   }\n616: \n617:   private cleanupSse(): void {\n618:     this.removeSseSubscription();\n619:     this.stopHeartbeat();\n620: \n621:     for (const [, clientRes] of this.sseClients) {\n622:       try {\n623:         clientRes.end();\n624:       } catch {\n625:         // ignore errors on cleanup\n626:       }\n627:     }\n628:     this.sseClients.clear();\n629:   }\n630: \n631:   // ── Route Handlers ──\n632: \n633:   private handleHealth(_req: http.IncomingMessage, res: http.ServerResponse): void {\n634:     const uptimeSeconds = Math.floor((Date.now() - this.startTime) / 1000);\n635:     this.sendJsonResponse(res, 200, this.successBody({\n636:       status: 'ok',\n637:       service: 'daemon-core',\n638:       version: '1.0.0',\n639:       uptime: uptimeSeconds,\n640:     }));\n641:   }\n642: \n643:   /**\n644:    * Handle /api/v1/healthz endpoint\n645:    * Returns detailed health check response for service management\n646:    * Public endpoint (no auth required) - used by service managers for health monitoring\n647:    */\n648:   private handleHealthZ(_req: http.IncomingMessage, res: http.ServerResponse): void {\n649:     const now = Date.now();\n650:     const uptimeSeconds = Math.floor((now - this.startTime) / 1000);\n651:     \n652:     // Get active client count from session registry if available\n653:     let activeClients = 0;\n654:     let pendingEvents = 0;\n655:     let lastEventTs: number | null = null;\n656:     \n657:     if (this.deps.sessionRegistry) {\n658:       try {\n659:         activeClients = (this.deps.sessionRegistry as any).getActiveSessionCount?.() ?? 0;\n660:       } catch {\n661:         // Ignore errors\n662:       }\n663:     }\n664:     \n665:     if (this.eventBus) {\n666:       try {\n667:         const bufferedEvents = this.eventBus.getBufferedEvents();\n668:         pendingEvents = bufferedEvents.length;\n669:         if (bufferedEvents.length > 0) {\n670:           lastEventTs = bufferedEvents[bufferedEvents.length - 1]!.ts;\n671:         }\n672:       } catch {\n673:         // Ignore errors\n674:       }\n675:     }\n676: \n677:     // Determine status based on current state\n678:     let status: 'ok' | 'degraded' | 'shutting-down' = 'ok';\n679:     // Note: isShuttingDown would need to be tracked by the daemon\n680:     \n681:     this.sendJsonResponse(res, 200, {\n682:       schema_version: '1.0',\n683:       status,\n684:       pid: process.pid,\n685:       version: '1.0.0',\n686:       startedAt: this.startTime,\n687:       uptimeSec: uptimeSeconds,\n688:       activeClients,\n689:       pendingEvents,\n690:       lastEventTs,\n691:     });\n692:   }\n693: \n694:   private handleRoot(_req: http.IncomingMessage, res: http.ServerResponse): void {\n695:     this.sendJsonResponse(res, 200, this.successBody({\n696:       status: 'ok',\n697:       service: 'daemon-core',\n698:     }));\n699:   }\n700: \n701:   private handleApiEndpoint(req: http.IncomingMessage, res: http.ServerResponse, body: string, match: RouteMatch): void {\n702:     this.sendJsonResponse(res, 200, this.successBody({\n703:       message: `API endpoint ${req.method} ${match.pathname} is registered`,\n704:       path: match.pathname,\n705:       params: match.params,\n706:     }));\n707:   }\n708: \n709:   private async handleStateRead(_req: http.IncomingMessage, res: http.ServerResponse, body: string): Promise<void> {\n710:     let request: Partial<StateReadRequest>;\n711:     try {\n712:       request = body ? JSON.parse(body) : {};\n713:     } catch {\n714:       this.sendJsonResponse(res, 400, this.errorBody('INVALID_JSON', 'Invalid JSON in request body'));\n715:       return;\n716:     }\n717: \n718:     const wid = request.workItemId;\n719: \n720:     if (!this.deps.stateManager) {\n721:       this.sendJsonResponse(res, 200, this.successBody({ message: 'state/read (no stateManager)', workItemId: wid ?? null }));\n722:       return;\n723:     }\n724: \n725:     try {\n726:       if (wid === 'all') {\n727:         const all = await (this.deps.stateManager as any).getAllStates();\n728:         return this.sendJsonResponse(res, 200, this.successBody({ workItems: all }));\n729:       }\n730:       if (!wid) {\n731:         return this.sendJsonResponse(res, 400, this.errorBody('MISSING_FIELDS', 'workItemId required'));\n732:       }\n733:       const state = await (this.deps.stateManager as any).getState(wid);\n734:       if (!state) {\n735:         return this.sendJsonResponse(res, 404, this.errorBody('NOT_FOUND', `${wid} not found`));\n736:       }\n737:       return this.sendJsonResponse(res, 200, this.successBody({ workItem: state }));\n738:     } catch (err) {\n739:       this.sendJsonResponse(res, 500, this.errorBody('INTERNAL_ERROR', (err as Error).message));\n740:     }\n741:   }\n742: \n743:   private async handleStateTransition(_req: http.IncomingMessage, res: http.ServerResponse, body: string): Promise<void> {\n744:     let request: Partial<StateTransitionRequest>;\n745:     try {\n746:       request = body ? JSON.parse(body) : {};\n747:     } catch {\n748:       this.sendJsonResponse(res, 400, this.errorBody('INVALID_JSON', 'Invalid JSON in request body'));\n749:       return;\n750:     }\n751: \n752:     const workItemId = request.workItemId;\n753:     const fromState = request.fromState;\n754:     const toState = request.toState;\n755:     if (!workItemId || fromState === undefined || !toState) {\n756:       this.sendJsonResponse(res, 400, this.errorBody('MISSING_FIELDS', 'workItemId / fromState / toState required'));\n757:       return;\n758:     }\n759: \n760:     if (!this.deps.workflowEngine) {\n761:       this.sendJsonResponse(res, 200, this.successBody({\n762:         message: 'state/transition (no workflowEngine)',\n763:         workItemId, fromState, toState,\n764:       }));\n765:       return;\n766:     }\n767: \n768:     try {\n769:       const result = await (this.deps.workflowEngine as any).transitionFull({\n770:         workItemId,\n771:         fromState,\n772:         toState,\n773:         evidence: (request as any).evidence ?? '',\n774:         workflowType: request.workflowType,\n775:         transitionContext: (request as any).transitionContext,\n776:         actor: null,\n777:       });\n778:       this.sendJsonResponse(res, 200, this.successBody(result));\n779:     } catch (err) {\n780:       this.sendJsonResponse(res, 409, this.errorBody('TRANSITION_REJECTED', (err as Error).message));\n781:     }\n782:   }\n783: \n784:   private async handleEventLog(_req: http.IncomingMessage, res: http.ServerResponse, body: string): Promise<void> {\n785:     let request: Partial<EventLogRequest>;\n786:     try {\n787:       request = body ? JSON.parse(body) : {};\n788:     } catch {\n789:       this.sendJsonResponse(res, 400, this.errorBody('INVALID_JSON', 'Invalid JSON in request body'));\n790:       return;\n791:     }\n792: \n793:     if (!request.projectId || !request.action || !request.category) {\n794:       this.sendJsonResponse(res, 400, this.errorBody('MISSING_FIELDS', 'projectId, action, category required'));\n795:       return;\n796:     }\n797: \n798:     if (!this.deps.eventLogger) {\n799:       this.sendJsonResponse(res, 200, this.successBody({ message: 'event/log (no eventLogger)', eventId: this.generateEventId() }));\n800:       return;\n801:     }\n802: \n803:     try {\n804:       const event: Event = {\n805:         schema_version: '1.0',\n806:         eventId: this.generateEventId(),\n807:         ts: Date.now() * 1_000_000,\n808:         monotonicSeq: Date.now(),\n809:         projectId: request.projectId,\n810:         workItemId: (request as any).workItemId,\n811:         actor: request.actor,\n812:         category: request.category as any,\n813:         action: request.action,\n814:         payload: request.payload ?? {},\n815:         metadata: {\n816:           schemaVersion: '1.0',\n817:           source: 'client',\n818:         },\n819:       };\n820: \n821:       await (this.deps.eventLogger as any).append(event);\n822: \n823:       if (this.eventBus) {\n824:         await this.eventBus.publish(event);\n825:       }\n826: \n827:       this.sendJsonResponse(res, 200, this.successBody({ eventId: event.eventId }));\n828:     } catch (err) {\n829:       this.sendJsonResponse(res, 500, this.errorBody('INTERNAL_ERROR', (err as Error).message));\n830:     }\n831:   }\n832: \n833:   private handleEventQuery(_req: http.IncomingMessage, res: http.ServerResponse, body: string): void {\n834:     let request: Partial<EventQueryRequest>;\n835:     try {\n836:       request = body ? JSON.parse(body) : {};\n837:     } catch {\n838:       this.sendJsonResponse(res, 400, this.errorBody('INVALID_JSON', 'Invalid JSON in request body'));\n839:       return;\n840:     }\n841:     console.log(`[API] event/query projectId=${request.projectId ?? '(all)'} action=${request.action ?? '(all)'}`);\n842:     this.sendJsonResponse(res, 200, this.successBody({\n843:       message: 'event/query placeholder',\n844:       events: [],\n845:     }));\n846:   }\n847: \n848:   private handleCasStore(_req: http.IncomingMessage, res: http.ServerResponse, body: string): void {\n849:     console.log(`[API] cas/store bodyLength=${body.length}`);\n850:     this.sendJsonResponse(res, 200, this.successBody({\n851:       message: 'cas/store placeholder',\n852:       contentSize: body.length,\n853:     }));\n854:   }\n855: \n856:   private handleCasRetrieve(req: http.IncomingMessage, res: http.ServerResponse): void {\n857:     const url = new URL(req.url ?? '/', `http://localhost:${this.port ?? 0}`);\n858:     const hash = url.searchParams.get('hash') ?? '';\n859:     console.log(`[API] cas/retrieve hash=${hash || '(not provided)'}`);\n860:     this.sendJsonResponse(res, 200, this.successBody({\n861:       message: 'cas/retrieve placeholder',\n862:       hash,\n863:     }));\n864:   }\n865: \n866:   private handleSessionList(_req: http.IncomingMessage, res: http.ServerResponse): void {\n867:     console.log('[API] session/list');\n868:     this.sendJsonResponse(res, 200, this.successBody({\n869:       message: 'session/list placeholder',\n870:       sessions: [],\n871:     }));\n872:   }\n873: \n874:   private async handleToolInvoke(_req: http.IncomingMessage, res: http.ServerResponse, body: string): Promise<void> {\n875:     let request: Partial<DispatcherRequest>;\n876:     try {\n877:       request = body ? JSON.parse(body) : {};\n878:     } catch {\n879:       this.sendJsonResponse(res, 400, this.errorBody('INVALID_JSON', 'Invalid JSON in request body'));\n880:       return;\n881:     }\n882: \n883:     if (!request.tool) {\n884:       this.sendJsonResponse(res, 400, this.errorBody('MISSING_TOOL', 'tool field required'));\n885:       return;\n886:     }\n887: \n888:     // Try real dispatcher first\n889:     if (this.deps.toolDispatcher) {\n890:       try {\n891:         const result = await this.deps.toolDispatcher.dispatch(request as DispatcherRequest);\n892:         this.sendJsonResponse(res, 200, this.successBody(result));\n893:       } catch (err) {\n894:         const msg = (err as Error).message;\n895:         if (msg.startsWith('Unknown tool:')) {\n896:           this.sendJsonResponse(res, 404, this.errorBody('UNKNOWN_TOOL', msg));\n897:         } else if (msg.startsWith('Permission denied:')) {\n898:           this.sendJsonResponse(res, 403, this.errorBody('PERMISSION_DENIED', msg));\n899:         } else {\n900:           this.sendJsonResponse(res, 500, this.errorBody('TOOL_ERROR', msg));\n901:         }\n902:       }\n903:       return;\n904:     }\n905: \n906:     // Fallback placeholder\n907:     this.sendJsonResponse(res, 501, this.errorBody('NOT_IMPLEMENTED', `Tool dispatch not available for ${request.tool}`));\n908:   }\n909: \n910:   private handleAdminStop(_req: http.IncomingMessage, res: http.ServerResponse): void {\n911:     console.log('[API] admin/stop — initiating graceful shutdown');\n912:     this.sendJsonResponse(res, 200, this.successBody({ message: 'shutdown initiated' }));\n913:     this.stop().catch((err: unknown) => {\n914:       console.error('[ADMIN] Error during admin stop:', err);\n915:     });\n916:   }\n917: \n918:   private async handleIngestRegister(\n919:     _req: http.IncomingMessage, res: http.ServerResponse, body: string\n920:   ): Promise<void> {\n921:     let request: { projectPath?: string };\n922:     try {\n923:       request = JSON.parse(body);\n924:     } catch {\n925:       return this.sendJsonResponse(res, 400, this.errorBody('INVALID_JSON', 'Invalid JSON'));\n926:     }\n927: \n928:     if (!request.projectPath) {\n929:       return this.sendJsonResponse(res, 400, this.errorBody('MISSING_PROJECT_PATH', 'projectPath required'));\n930:     }\n931: \n932:     try {\n933:       const ctx = await (this.deps.projectManager as any).registerProject(request.projectPath);\n934:       const identity = await (this.deps.sessionRegistry as any).registerPluginSession(ctx.projectId, request.projectPath);\n935:       this.sendJsonResponse(res, 200, this.successBody({\n936:         sessionId: identity.sessionId,\n937:         projectId: ctx.projectId,\n938:         mode: this.config.getMode(),\n939:       }));\n940:     } catch (err) {\n941:       // B2: Handle PROJECT_NOT_INITIALIZED\n942:       if ((err as Error).message === 'PROJECT_NOT_INITIALIZED') {\n943:         this.sendJsonResponse(res, 409, {\n944:           error: 'PROJECT_NOT_INITIALIZED',\n945:           message: '项目未初始化。请先完成启动流程（步骤 1-4）再注册。',\n946:           projectPath: request.projectPath,\n947:         });\n948:         return;\n949:       }\n950:       if (isWALWriteError(err)) {\n951:         res.setHeader('Retry-After', '5');\n952:         this.sendJsonResponse(res, 503, { error: 'WAL_WRITE_FAILED', message: 'WAL write failed — event not accepted. Please retry.' });\n953:       } else {\n954:         this.sendJsonResponse(res, 500, this.errorBody('REGISTER_FAILED', (err as Error).message));\n955:       }\n956:     }\n957:   }\n958: \n959:   // ── Ingest Event Handling ──\n960: \n961:   /**\n962:    * Handle POST /api/v1/ingest/event\n963:    * \n964:    * Parses the event request, validates JSON, and routes to the appropriate\n965:    * subsystem handler based on event type.  Satisfies CP-4: must return an\n966:    * HTTP response within 15 s even when subsystems fail or time out.\n967:    */\n968:   private async handleIngestEvent(\n969:     _req: http.IncomingMessage, res: http.ServerResponse, body: string\n970:   ): Promise<void> {\n971:     let request: { sessionId?: string; type?: string; data?: unknown; ts?: number };\n972:     try {\n973:       request = JSON.parse(body);\n974:     } catch {\n975:       return this.sendJsonResponse(res, 400, this.errorBody('INVALID_JSON', 'Invalid JSON'));\n976:     }\n977: \n978:     // Backward compatibility: accept events without sessionId\n979:     if (!request.sessionId) {\n980:       console.warn('[INGEST] Event received without sessionId — plugin may need upgrade');\n981:     }\n982: \n983:     // CP-4: 15 s overall timeout — only send one response\n984:     let responded = false;\n985:     const respond = (status: number, data: unknown) => {\n986:       if (!responded) {\n987:         responded = true;\n988:         this.sendJsonResponse(res, status, data);\n989:       }\n990:     };\n991: \n992:     const overallTimeout = new Promise<void>((resolve) => {\n993:       setTimeout(() => {\n994:         respond(200, this.successBody({\n995:           received: true,\n996:           type: request.type ?? 'unknown',\n997:           warning: 'Event processing timed out',\n998:         }));\n999:         resolve();\n1000:       }, 15_000);\n1001:     });\n1002: \n1003:     const processing = (async () => {\n1004:       try {\n1005:         const extra = await this.routeIngestEvent(request);\n1006:         respond(200, this.successBody({\n1007:           received: true,\n1008:           type: request.type ?? 'unknown',\n1009:           ...(extra ?? {}),\n1010:         }));\n1011:     } catch (err) {\n1012:         if (isWALWriteError(err)) {\n1013:           res.setHeader('Retry-After', '5');\n1014:           respond(503, { error: 'WAL_WRITE_FAILED', message: 'WAL write failed — event not accepted. Please retry.' });\n1015:         } else {\n1016:           console.error(`[INGEST] Failed to process ${request.type}:`, err);\n1017:           respond(200, this.successBody({\n1018:             received: true,\n1019:             type: request.type ?? 'unknown',\n1020:             warning: `Event logged but processing failed: ${(err as Error).message}`,\n1021:           }));\n1022:         }\n1023:       }\n1024:     })();\n1025: \n1026:     await Promise.race([processing, overallTimeout]);\n1027:   }\n1028: \n1029:   /**\n1030:    * Route an ingest event to the appropriate subsystem handler.\n1031:    * \n1032:    * Returns optional extra data to merge into the HTTP response.\n1033:    */\n1034:   private async routeIngestEvent(\n1035:     request: { sessionId?: string; type?: string; data?: unknown; ts?: number }\n1036:   ): Promise<Record<string, unknown> | undefined> {\n1037:     const sessionId = request.sessionId ?? '';\n1038:     const type = request.type ?? '';\n1039:     const data = request.data;\n1040:     const ts = request.ts ?? 0;\n1041: \n1042:     switch (type) {\n1043:       case 'tool.invoking':\n1044:         await this.handleToolInvoking(sessionId, data, ts);\n1045:         break;\n1046:       case 'tool.invoked':\n1047:         await this.handleToolInvoked(sessionId, data, ts);\n1048:         break;\n1049:       case 'opencode.event':\n1050:         await this.handleOpenCodeEvent(sessionId, data, ts);\n1051:         break;\n1052:       case 'session.compacting':\n1053:         await this.handleSessionCompacting(sessionId, data, ts);\n1054:         break;\n1055:       case 'chat.params':\n1056:         await this.handleChatParams(sessionId, data, ts);\n1057:         break;\n1058:       case 'chat.headers':\n1059:         await this.handleChatHeaders(sessionId, data, ts);\n1060:         break;\n1061:       case 'shell.env':\n1062:         return { env: await this.handleShellEnv(sessionId, data) };\n1063:       default:\n1064:         console.warn(`[INGEST] Unknown event type: ${type}`);\n1065:     }\n1066:     return undefined;\n1067:   }\n1068: \n1069:   // ── Event Type Handlers ──\n1070: \n1071:   /**\n1072:    * Handle tool.invoking events — PermissionEngine evaluation + SessionRegistry touch.\n1073:    * Timeout: 5 s. On timeout → default allow (phase 1: only log, never intercept).\n1074:    */\n1075:   private async handleToolInvoking(\n1076:     sessionId: string, data: unknown, _ts: number\n1077:   ): Promise<void> {\n1078:     const payload = (data ?? {}) as { tool?: string; callID?: string; args?: Record<string, unknown> };\n1079: \n1080:     // 1. Update session activity (non-critical)\n1081:     try {\n1082:       await this.deps.sessionRegistry?.touch?.(sessionId);\n1083:     } catch (err) {\n1084:       if (isWALWriteError(err)) {\n1085:         console.warn(`[INGEST] WAL write error during touch for session ${sessionId}: ${err.message}`);\n1086:       }\n1087:       // non-blocking\n1088:     }\n1089: \n1090:     // 2. PermissionEngine evaluation (phase 1: log only, don't intercept)\n1091:     if (this.deps.permissionEngine && payload.tool) {\n1092:       try {\n1093:         const allowed = await this.withTimeout(\n1094:           this.deps.permissionEngine.checkPermission(\n1095:             sessionId,\n1096:             'tool.invoking',\n1097:             payload.tool,\n1098:             { args: payload.args ?? {}, callID: payload.callID },\n1099:           ),\n1100:           5_000,\n1101:           true,  // default allow on timeout\n1102:         );\n1103: \n1104:         // Phase 1: log the evaluation result\n1105:         await this.deps.eventLogger?.append?.({\n1106:           eventId: this.generateEventId(),\n1107:           ts: Date.now(),\n1108:           projectId: this.deps.sessionRegistry?.getProjectPath?.(sessionId) ?? '',\n1109:           category: 'permission' as any,\n1110:           action: 'permission.evaluated',\n1111:           payload: {\n1112:             tool: payload.tool,\n1113:             decision: allowed ? 'allow' : 'deny',\n1114:             sessionId,\n1115:           },\n1116:           metadata: { schemaVersion: '1.0', source: 'daemon' },\n1117:         });\n1118:       } catch (err) {\n1119:         console.error(`[INGEST] PermissionEngine error for ${payload.tool}:`, err);\n1120:       }\n1121:     }\n1122:   }\n1123: \n1124:   /**\n1125:    * Handle tool.invoked events — log via EventLogger.\n1126:    * Timeout: 3 s. On timeout → lose this log entry (non-critical path).\n1127:    */\n1128:   private async handleToolInvoked(\n1129:     sessionId: string, data: unknown, ts: number\n1130:   ): Promise<void> {\n1131:     const payload = (data ?? {}) as Record<string, unknown>;\n1132:     try {\n1133:       await this.withTimeout(\n1134:         (async () => {\n1135:           await this.deps.eventLogger?.append?.({\n1136:             eventId: this.generateEven