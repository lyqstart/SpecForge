rc\\directory-layout.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * directory-layout.ts — SpecForge V6 项目目录布局的单一真相源（Single Source of Truth）\n3:  *\n4:  * 本模块定义 SpecForge 项目根目录下 `.specforge/` 目录的全部子路径常量，\n5:  * 是方案 A（docs/proposals/2026-05-29-directory-structure-governance.md §6.2）\n6:  * 三层架构中\"Schema 层\"的核心交付物，亦是 P0 阶段的核心产物之一。\n7:  *\n8:  * 设计要点：\n9:  * - 使用 TypeScript `as const` 声明 `SPEC_DIR_NAME` 和 `LAYOUT` 字典，\n10:  *   使 `keyof typeof LAYOUT` 成为字面量联合类型——这是方案 A §8\n11:  *   \"三道强制门\"中防线 A（编译期防御）的基础设施。\n12:  * - `LAYOUT` 字典中的值是相对于 `<projectRoot>/.specforge/` 的子路径。\n13:  * - 通过 `resolveProjectPath()` / `specPath()` / `agentRunArchivePath()`\n14:  *   三个路径构造函数对外提供路径生成能力——后续 P1 阶段的硬编码字符串\n15:  *   替换工作必须经由这三个函数收口。\n16:  *\n17:  * P0 阶段的隔离承诺：本文件在 P0 完成后不会被任何现有 daemon-core 或\n18:  * tools 代码 import，是孤立模块。首次集成发生在 P1 的代码切换任务中。\n19:  *\n20:  * 关联文档：\n21:  * - 方案 A（docs/proposals/2026-05-29-directory-structure-governance.md）\n22:  * - ADR-006（docs/adr/ADR-006-specforge-dir-naming.md）\n23:  * - WI-010 refactor_plan.md（任务 T1）\n24:  */\n25: \n26: /// <reference types=\"node\" />\n27: \n28: // 使用 Node.js 内置 path 模块（通过 node: 前缀显式标识）。\n29: // 仅依赖 path.join，不引入任何外部依赖。\n30: import * as path from 'node:path';\n31: \n32: // 使用 Node.js 内置 os 模块（用于用户级路径的 os.homedir()）。\n33: import * as os from 'node:os';\n34: \n35: // ---------------------------------------------------------------------------\n36: // SPEC_DIR_NAME — 项目根下 SpecForge 目录的权威名称（带点）\n37: // ---------------------------------------------------------------------------\n38: \n39: /**\n40:  * SpecForge 在用户项目根目录下创建的工具目录名。\n41:  *\n42:  * **必须使用带点形式 `.specforge`**（与 `.git/` / `.kiro/` / `.opencode/`\n43:  * 风格一致；带点目录在 Unix/Windows 文件管理器默认隐藏，符合\n44:  * \"用户不应直接编辑工具内部状态\"的语义）。\n45:  *\n46:  * 此处使用 `as const` 声明：任何拼写错误如 `'.SpecForge'` / `'specforge'`\n47:  * 在编译期就被拒绝，这是方案 A §8 防线 A 的核心机制。\n48:  *\n49:  * @example\n50:  * ```ts\n51:  * import { SPEC_DIR_NAME } from '@specforge/types';\n52:  * // SPEC_DIR_NAME === '.specforge'\n53:  * ```\n54:  */\n55: export const SPEC_DIR_NAME = '.specforge' as const;\n56: \n57: // ---------------------------------------------------------------------------\n58: // LAYOUT — `.specforge/` 下各子路径的权威字典\n59: // ---------------------------------------------------------------------------\n60: \n61: /**\n62:  * `.specforge/` 目录下所有子路径的权威字典。\n63:  *\n64:  * 路径值是相对于 `<projectRoot>/.specforge/` 的子路径片段，不含前导\n65:  * `.specforge/`，由 {@link resolveProjectPath} 等函数负责前缀拼接。\n66:  *\n67:  * 顶层分区（committed 区 vs gitignored 区）依据方案 A §6.2：\n68:  * - **committed 区**（提交到 Git）：manifest / config / specs / knowledge\n69:  * - **gitignored 区**（运行时数据）：runtime / logs / archive / sessions / cas\n70:  *\n71:  * 嵌套对象 `configFiles` 是为提升可发现性而设计的\"分组键空间\"，\n72:  * 嵌套键不参与 {@link resolveProjectPath} 的 key 选择，但可通过\n73:  * 直接路径拼接使用（见 JSDoc 示例）。\n74:  *\n75:  * @example\n76:  * ```ts\n77:  * import { LAYOUT, SPEC_DIR_NAME } from '@specforge/types';\n78:  * import * as path from 'path';\n79:  *\n80:  * // 顶层 key 用法\n81:  * LAYOUT.runtime;            // 'runtime'\n82:  * LAYOUT.runtimeWal;         // 'runtime/wal.jsonl'\n83:  *\n84:  * // 嵌套 configFiles 用法\n85:  * LAYOUT.configFiles.projectRules;  // 'config/project-rules.md'\n86:  * path.join('/proj', SPEC_DIR_NAME, LAYOUT.configFiles.projectRules);\n87:  * // → '/proj/.specforge/config/project-rules.md'\n88:  * ```\n89:  */\n90: export const LAYOUT = {\n91:   // ---- committed 区（提交到 Git）----\n92:   /** Project manifest（committed）— `<root>/.specforge/manifest.json` */\n93:   manifest: 'manifest.json',\n94: \n95:   /** 项目配置目录（committed）— `<root>/.specforge/config/` */\n96:   config: 'config',\n97: \n98:   /** 项目配置文件的\"分组键空间\"。嵌套键不进入 {@link resolveProjectPath}，\n99:    *  应通过直接路径拼接或专用辅助函数使用。 */\n100:   configFiles: {\n101:     /** `<root>/.specforge/config/project-rules.md` */\n102:     projectRules: 'config/project-rules.md',\n103:     /** `<root>/.specforge/config/dev-environment.md` */\n104:     devEnv: 'config/dev-environment.md',\n105:     /** `<root>/.specforge/config/prod-environment.md` */\n106:     prodEnv: 'config/prod-environment.md',\n107:     /** `<root>/.specforge/config/project.json` */\n108:     project: 'config/project.json',\n109:     /** `<root>/.specforge/config/risk_policy.json` */\n110:     riskPolicy: 'config/risk_policy.json',\n111:     /** `<root>/.specforge/config/skill_fragments.json` */\n112:     skillFragments: 'config/skill_fragments.json',\n113:   },\n114: \n115:   /** Work Item 规格目录（committed）— `<root>/.specforge/specs/` */\n116:   specs: 'specs',\n117: \n118:   /** specs 目录的 README（committed）— `<root>/.specforge/specs/README.md` */\n119:   specsReadme: 'specs/README.md',\n120: \n121:   /** Knowledge 目录（committed）— `<root>/.specforge/knowledge/` */\n122:   knowledge: 'knowledge',\n123: \n124:   /** Knowledge Graph 数据（committed）— `<root>/.specforge/knowledge/graph.json` */\n125:   knowledgeGraph: 'knowledge/graph.json',\n126: \n127:   // ---- gitignored 区（运行时数据，不提交 Git）----\n128:   /** 运行时状态目录（gitignored）— `<root>/.specforge/runtime/` */\n129:   runtime: 'runtime',\n130: \n131:   /** 写前日志（gitignored）— `<root>/.specforge/runtime/wal.jsonl` */\n132:   runtimeWal: 'runtime/wal.jsonl',\n133: \n134:   /** 持久化状态（gitignored）— `<root>/.specforge/runtime/state.json` */\n135:   runtimeState: 'runtime/state.json',\n136: \n137:   /** 状态快照目录（gitignored）— `<root>/.specforge/runtime/checkpoints/` */\n138:   runtimeCheckpoints: 'runtime/checkpoints',\n139: \n140:   /** 日志目录（gitignored）— `<root>/.specforge/logs/` */\n141:   logs: 'logs',\n142: \n143:   /** 遥测日志（gitignored）— `<root>/.specforge/logs/telemetry.jsonl` */\n144:   logsTelemetry: 'logs/telemetry.jsonl',\n145: \n146:   /** 追踪日志（gitignored）— `<root>/.specforge/logs/trace.jsonl` */\n147:   logsTrace: 'logs/trace.jsonl',\n148: \n149:   /** 工具调用日志（gitignored）— `<root>/.specforge/logs/tool_calls.jsonl` */\n150:   logsToolCalls: 'logs/tool_calls.jsonl',\n151: \n152:   /** 成本日志（gitignored）— `<root>/.specforge/logs/cost.jsonl` */\n153:   logsCost: 'logs/cost.jsonl',\n154: \n155:   /** 会话日志（gitignored）— `<root>/.specforge/logs/conversations.jsonl` */\n156:   logsConversations: 'logs/conversations.jsonl',\n157: \n158:   /** Agent Run 归档根目录（gitignored）— `<root>/.specforge/archive/` */\n159:   archive: 'archive',\n160: \n161:   /** Agent Run 归档子目录（gitignored）— `<root>/.specforge/archive/agent_runs/` */\n162:   archiveAgentRuns: 'archive/agent_runs',\n163: \n164:   /** 会话归档目录（gitignored）— `<root>/.specforge/sessions/` */\n165:   sessions: 'sessions',\n166: \n167:   /** 内容寻址存储（gitignored）— `<root>/.specforge/cas/` */\n168:   cas: 'cas',\n169: } as const;\n170: \n171: /**\n172:  * `LAYOUT` 字典的\"扁平 key\"联合类型。\n173:  *\n174:  * 注：嵌套对象 `configFiles` 本身计入键集（因为它是 LAYOUT 的直接 key），\n175:  * 但 `configFiles.*` 的嵌套键不参与该联合类型。\n176:  */\n177: export type LayoutKey = keyof typeof LAYOUT;\n178: \n179: // ---------------------------------------------------------------------------\n180: // 路径构造函数（方案 A §6.2 必需的三个入口）\n181: // ---------------------------------------------------------------------------\n182: \n183: /**\n184:  * 拼合 `<projectRoot>/.specforge/<LAYOUT[key]>/<...subpath>`，\n185:  * 是后续 P1 阶段全量替换硬编码路径字符串的唯一通用入口。\n186:  *\n187:  * **限制**：`key` 必须是 `LAYOUT` 的顶层 key（含 `'configFiles'`），\n188:  * 嵌套对象 `configFiles` 的子键如 `projectRules` 不能作为 `key` 传入。\n189:  * 若需访问嵌套键，请直接使用 `path.join(projectRoot, SPEC_DIR_NAME, LAYOUT.configFiles.projectRules)`。\n190:  *\n191:  * @param projectRoot 项目根目录绝对路径（如 `/home/user/my-project`）\n192:  * @param key `LAYOUT` 的顶层 key\n193:  * @param subpath 可变长度子路径段，会被 `path.join` 依序拼接到结果末尾\n194:  * @returns 平台原生路径字符串（Windows 用 `\\`，Unix 用 `/`）\n195:  *\n196:  * @example\n197:  * ```ts\n198:  * resolveProjectPath('/proj', 'runtime');\n199:  * // → '/proj/.specforge/runtime'\n200:  *\n201:  * resolveProjectPath('/proj', 'specs', 'WI-001', 'design.md');\n202:  * // → '/proj/.specforge/specs/WI-001/design.md'\n203:  *\n204:  * resolveProjectPath('/proj', 'archiveAgentRuns');\n205:  * // → '/proj/.specforge/archive/agent_runs'\n206:  * ```\n207:  */\n208: export function resolveProjectPath(\n209:   projectRoot: string,\n210:   key: LayoutKey,\n211:   ...subpath: string[]\n212: ): string {\n213:   const value = LAYOUT[key];\n214:   // 嵌套对象（如 LAYOUT.configFiles）通过 key 传入时，仅拼到 .specforge/<key 名>\n215:   // 不展开内部子项；调用方应改用 LAYOUT.configFiles.<sub> 直接拼接。\n216:   const segment = typeof value === 'string' ? value : key;\n217:   return path.join(projectRoot, SPEC_DIR_NAME, segment, ...subpath);\n218: }\n219: \n220: /**\n221:  * 构造单个 Work Item 规格文件的绝对路径，等价于\n222:  * `<projectRoot>/.specforge/specs/<workItemId>/<file>`。\n223:  *\n224:  * 该函数避免上层调用每次手拼 `'specs/' + wi`，是 specs 子路径的专用入口。\n225:  *\n226:  * @param projectRoot 项目根目录绝对路径\n227:  * @param workItemId Work Item ID，如 `'WI-001'`、`'WI-010'`（允许含连字符）\n228:  * @param file 文件名，如 `'requirements.md'`、`'design.md'`、`'refactor_plan.md'`\n229:  * @returns 平台原生路径字符串\n230:  *\n231:  * @example\n232:  * ```ts\n233:  * specPath('/proj', 'WI-001', 'design.md');\n234:  * // → '/proj/.specforge/specs/WI-001/design.md'\n235:  *\n236:  * specPath('/proj', 'WI-010', 'refactor_plan.md');\n237:  * // → '/proj/.specforge/specs/WI-010/refactor_plan.md'\n238:  * ```\n239:  */\n240: export function specPath(\n241:   projectRoot: string,\n242:   workItemId: string,\n243:   file: string,\n244: ): string {\n245:   return path.join(projectRoot, SPEC_DIR_NAME, LAYOUT.specs, workItemId, file);\n246: }\n247: \n248: /**\n249:  * 构造 Agent Run 归档目录的绝对路径，等价于\n250:  * `<projectRoot>/.specforge/archive/agent_runs/<workItemId>-<agentType>-<runIndex>`。\n251:  *\n252:  * 该函数避免上层手拼 `${wi}-${agent}-${idx}` 字符串格式，\n253:  * 是 Agent Run 归档路径的专用入口。`runIndex` 直接转字符串拼接，\n254:  * 不做零填充（与现有 daemon-core 行为保持一致）。\n255:  *\n256:  * @param projectRoot 项目根目录绝对路径\n257:  * @param workItemId Work Item ID\n258:  * @param agentType Agent 类型字符串，如 `'sf-design'` / `'sf-executor'`\n259:  * @param runIndex Run 序号（自然数，从 1 起）\n260:  * @returns 平台原生路径字符串\n261:  *\n262:  * @example\n263:  * ```ts\n264:  * agentRunArchivePath('/proj', 'WI-001', 'sf-design', 1);\n265:  * // → '/proj/.specforge/archive/agent_runs/WI-001-sf-design-1'\n266:  *\n267:  * agentRunArchivePath('/proj', 'WI-010', 'sf-executor', 99);\n268:  * // → '/proj/.specforge/archive/agent_runs/WI-010-sf-executor-99'\n269:  * ```\n270:  */\n271: export function agentRunArchivePath(\n272:   projectRoot: string,\n273:   workItemId: string,\n274:   agentType: string,\n275:   runIndex: number,\n276: ): string {\n277:   const dirName = `${workItemId}-${agentType}-${runIndex}`;\n278:   return path.join(\n279:     projectRoot,\n280:     SPEC_DIR_NAME,\n281:     LAYOUT.archiveAgentRuns,\n282:     dirName,\n283:   );\n284: }\n285: \n286: // ---------------------------------------------------------------------------\n287: // SPEC_USER_DIR_NAME — 用户主目录下 SpecForge 目录的权威名称\n288: // ---------------------------------------------------------------------------\n289: \n290: /**\n291:  * SpecForge 用户级数据目录名（与 SPEC_DIR_NAME 相同，用于用户主目录下）。\n292:  *\n293:  * 与 {@link SPEC_DIR_NAME} 不同的是，该常量用于 `~/.specforge/` 下的\n294:  * 用户级全局数据（非项目级），如全局运行时状态、日志、模板等。\n295:  *\n296:  * @example\n297:  * ```ts\n298:  * import { SPEC_USER_DIR_NAME } from '@specforge/types';\n299:  * // SPEC_USER_DIR_NAME === '.specforge'\n300:  * ```\n301:  */\n302: export const SPEC_USER_DIR_NAME = '.specforge' as const;\n303: \n304: // ---------------------------------------------------------------------------\n305: // USER_LAYOUT — `~/.specforge/` 下各子路径的权威字典（用户级）\n306: // ---------------------------------------------------------------------------\n307: \n308: /**\n309:  * `~/.specforge/` 目录下各子路径的权威字典（用户级）。\n310:  *\n311:  * 路径值是相对于 `~/.specforge/` 的子路径片段，不含前导\n312:  * `.specforge/`，由 {@link resolveUserPath} 函数负责前缀拼接。\n313:  *\n314:  * @example\n315:  * ```ts\n316:  * import { USER_LAYOUT, SPEC_USER_DIR_NAME } from '@specforge/types';\n317:  * import * as path from 'path';\n318:  * import * as os from 'os';\n319:  *\n320:  * USER_LAYOUT.runtime;           