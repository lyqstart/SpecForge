65: /**\n166:  * 检测降级：source version < manifest version\n167:  */\n168: function detectDowngrade(sourceVersion: string, manifestVersion: string): boolean {\n169:   const source = parseVersion(sourceVersion)\n170:   const manifest = parseVersion(manifestVersion)\n171:   return compareVersions(source, manifest) < 0\n172: }\n173: \n174: // ============================================================\n175: // Public API\n176: // ============================================================\n177: \n178: /**\n179:  * 执行完整 Reconcile 流程\n180:  *\n181:  * 编排顺序（N1 修复）：\n182:  * 1. acquireLock()（仅 CLI scope）\n183:  * 2. preflightTarget(targetDir)（不依赖 DesiredState）\n184:  * 3. recoverPartialCommit()（S4 修复）\n185:  * 4. provider.buildDesiredState()\n186:  * 5. 读取并验证 Manifest（M3 分层校验）\n187:  * 6. 降级检测（source version < manifest version）\n188:  * 7. buildCurrentState(targetDir, manifest)\n189:  * 8. generatePlan(desired, current, options)\n190:  * 9. 模式特定过滤（repair_missing 仅保留 create）\n191:  * 10. preflightPlan(targetDir, desiredState, plan)\n192:  * 11. executePlan(plan, options)\n193:  * 12. commit(result)（opencode.json → Manifest）\n194:  * 13. generatedFileHandler.executeCleanup()\n195:  * 14. 释放锁\n196:  *\n197:  * 模式特定行为：\n198:  * - full: 完整流程\n199:  * - fresh_install: 跳过 Manifest 读取，CurrentState 为空\n200:  * - repair_missing: 跳过降级检测、跳过 opencode.json 合并、仅 create\n201:  * - repair_full: 跳过降级检测、跳过 opencode.json 合并、全部动作\n202:  */\n203: export async function reconcile(options: ReconcileOptions): Promise<ReconcileResult> {\n204:   const { sourceDir, targetDir, force, mode, scope, provider, mergeOptions } = options\n205: \n206:   let lockHandle: LockHandle | undefined\n207: \n208:   try {\n209:     // ============================================================\n210:     // Step 1: 获取锁（仅 CLI scope）\n211:     // ============================================================\n212:     if (shouldAcquireLock(mode, scope)) {\n213:       const lockResult = await acquireLock({\n214:         targetDir,\n215:         command: mode === \"fresh_install\" ? \"install\" : \"upgrade\",\n216:       })\n217:       if (!lockResult.acquired) {\n218:         return buildFailureResult(\n219:           `Failed to acquire lock: ${lockResult.reason}. Another operation may be in progress (PID: ${lockResult.holder.pid}).`\n220:         )\n221:       }\n222:       lockHandle = lockResult.handle\n223:     }\n224: \n225:     // ============================================================\n226:     // Step 2: preflightTarget（不依赖 DesiredState）\n227:     // ============================================================\n228:     const targetPreflight = await preflightTarget({ targetDir })\n229:     if (!targetPreflight.passed) {\n230:       const errors = targetPreflight.errors.map((e) => e.code).join(\", \")\n231:       return {\n232:         ...buildFailureResult(`Target preflight failed: ${errors}`),\n233:         targetPreflightPassed: false,\n234:       }\n235:     }\n236: \n237:     // ============================================================\n238:     // Step 3: 恢复中断的提交（S4 修复, Requirements 4.3, 4.5）\n239:     //\n240:     // 检测 partial_commit.journal 是否存在：\n241:     // - 存在 → 读取 manifest_payload → 直接写入 Manifest → 删除 journal\n242:     // - 恢复后继续正常 reconcile 流程\n243:     // ============================================================\n244:     const recoveryResult = await recoverPartialCommit(targetDir)\n245:     const partialCommitRecovered = recoveryResult !== null\n246: \n247:     // ============================================================\n248:     // Step 4: 构建 DesiredState\n249:     // ============================================================\n250:     const discoveryResult: DiscoveryResult = await provider.buildDesiredState()\n251:     if (!discoveryResult.ok) {\n252:       return {\n253:         ...buildFailureResult(\n254:           `Discovery failed: ${discoveryResult.error.code} — ${\n255:             \"message\" in discoveryResult.error\n256:              