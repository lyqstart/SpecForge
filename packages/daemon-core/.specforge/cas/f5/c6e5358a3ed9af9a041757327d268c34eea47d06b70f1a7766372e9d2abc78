     const commitOptions: CommitOptions = {\n400:       targetDir,\n401:       executionResult: execution,\n402:       desiredState,\n403:       scope,\n404:       downgradeResult,\n405:     }\n406: \n407:     // opencode.json 合并选项（仅 user_shared scope 且不跳过合并时）\n408:     if (scope === \"user_shared\" && !shouldSkipOpencodeMerge(mode) && mergeOptions) {\n409:       // 构建 agents 列表\n410:       const agents = Array.from(desiredState.entries.values()).filter(\n411:         (e) => e.componentType === \"agent\"\n412:       )\n413:       commitOptions.mergeOptions = {\n414:         targetDir,\n415:         agents,\n416:         sourceConfig: mergeOptions.sourceConfig,\n417:         preserveUserOverrides: mergeOptions.preserveUserOverrides,\n418:         backupBeforeDowngrade: mergeOptions.backupBeforeDowngrade,\n419:       }\n420:     }\n421: \n422:     const commitResult = await commit(commitOptions)\n423: \n424:     // ============================================================\n425:     // Step 13: 清理生成文件\n426:     // ============================================================\n427:     if (execution.success && commitResult.manifestWritten) {\n428:       const cleanupPlan = await generatedFileHandler.checkForCleanup(targetDir)\n429:       await generatedFileHandler.executeCleanup(cleanupPlan)\n430:     }\n431: \n432:     // ============================================================\n433:     // 构建最终结果\n434:     // ============================================================\n435:     return {\n436:       success: execution.success && commitResult.manifestWritten,\n437:       plan,\n438:       execution,\n439:       commitResult,\n440:       downgradeDetected,\n441:       downgradeResult,\n442:       targetPreflightPassed: true,\n443:       planPreflightPassed: true,\n444:       partialCommitRecovered,\n445:     }\n446:   } catch (err) {\n447:     // R7.5: degraded 模式处理 — reconcile 失败时不崩溃\n448:     const errorMessage = err instanceof Error ? err.message : String(err)\