chedHandshake = handshake;\n304:       this.resetBackoff();\n305:       this.pendingEvent = null;\n306:       return { ok: true, dropped: false, reason: \"success\" };\n307:     }\n308: \n309:     return this.startBackoff(sessionId, type, data);\n310:   }\n311: \n312:   private enterDegradedMode(): void {\n313:     this.degraded = true;\n314:     this.pendingEvent = null;\n315:     this.clearBackoffTimer();\n316:     this.printDegradedWarningOnce();\n317:   }\n318: \n319:   private printDegradedWarningOnce(): void {\n320:     if (!this.degradedWarningPrinted) {\n321:       console.error(\n322:         \"[specforge] Daemon unreachable for over 60 seconds, entering degraded mode. \" +\n323:           \"See 'specforge daemon status' for details.\"\n324:       );\n325:       this.degradedWarningPrinted = true;\n326:     }\n327:   }\n328: \n329:   private resetBackoff(): void {\n330:     this.cumulativeBackoffMs = 0;\n331:     this.retryCount = 0;\n332:     this.currentBackoffMs = this.options.initialDelayMs;\n333:   }\n334: \n335:   private clearBackoffTimer(): void {\n336:     if (this.backoffTimer) {\n337:       clearTimeout(this.backoffTimer);\n338:       this.backoffTimer = null;\n339:     }\n340:   }\n341: }\n342: \n343: export function createReconnectingDaemonClient(\n344:   options?: ReconnectingDaemonClientOptions\n345: ): ReconnectingDaemonClient {\n346:   return new ReconnectingDaemonClient(options);\n347: }\n\n(End of file - total 347 lines)\n</content>","metadata":{"preview":"/**\n * Self-contained ReconnectingDaemonClient for SpecForge OpenCode plugin.\n *\n * This is a dependency-free copy of the ReconnectingDaemonClient from\n * packages/service-management/src/plugin/reconnecting-daemon-client.ts,\n * adapted to work without any @specforge/* or relative-package imports.\n *\n * All external types and constants are inlined so this single file can be\n * deployed to ~/.config/opencode/scripts/lib/ and imported by the plugin\n * without requiring the full mo