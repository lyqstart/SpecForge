> powershell > cmd；macOS/Linux 优先 bash > zsh\n- **强制 UTF-8 编码**：解决 Windows 中文乱码（chcp 65001 + Console.OutputEncoding）\n- **危险命令拦截**：`rm -rf /`、`sudo`、`curl ... | sh`、`format` 等直接拒绝执行\n- **禁用 cd / cat / find / grep / mkdir 等系统命令**：拒绝并给出替代建议（用 cwd 参数 / read_file / file_search / grep_search / fs_write）\n- **OS 级 hard timeout**：默认 60s，超时 SIGKILL 必返回，agent 不死等\n- **stdout/stderr 分离 + 截断到 4 KB**：避免上下文炸\n- **审计日志**：写入 `.specforge/logs/shell-history.jsonl`，便于排查\n\n### 工具替代速查（违反将被 sf_safe_bash 拒绝）\n\n| 错误用法 | 正确用法 |\n|---|---|\n| `cd <dir> && <cmd>` | 调用 sf_safe_bash 时传 `cwd: \"<dir>\"` 参数 |\n| `cat foo.txt` | 用 `read_file` 工具 |\n| `find . -name \"*.ts\"` | 用 `file_search` 工具 |\n| `grep \"pattern\" file.txt` | 用 `grep_search` 工具 |\n| `mkdir -p dir/sub` | 用 `fs_write` 写文件（自动建目录） |\n| `echo \"x\" > file` | 用 `fs_write` 工具 |\n| `cat << EOF\\n...\\nEOF`（heredoc） | 写到临时文件再调用 |\n| `python -c \"import x\\nx()\"`（多行 -c） | 写到 `tmp.py` 再 `python tmp.py` |\n| `bash -c \"long script\"` | 写到 `tmp.sh` 再 `bash tmp.sh` |\n\n### 失败处理\n\n`sf_safe_bash` 返回 JSON 含 `success` / `exitCode` / `stdout` / `stderr` / `rejected` / `hint` / `suggestion` 字段：\n\n- `rejected: true` → **不要重试同样的命令**，按 `suggestion` 字段调整后再调用（直接换写法重试常常踩另一个约束）\n- `timeout: true` → 命令在限定时间内未完成，被 SIGKILL；检查是否资源泄漏 / 网络挂起 / 死锁\n- `exitCode != 0` 且 `success: false` → 业务失败，看 `stderr` 和 `hint` 决定下一步\n\n### 紧急逃生通道\n\n只有 `sf-orchestrator` 保留 `bash: allow`，作为 sf_safe_bash 不可用（daemon 异常）时的应急通道。**普通工作流不应使用 orchestrator 的 bash 权限**。\n\n---\n\n## SpecForge 框架核心规则\n\n1. 所有 agent 必须遵守 `~/.config/opencode/agents/_AGENT_BASE.md` 的底线规则\n2. 状态流转必须通过 `sf_state_transition` 工具（仅 Orchestrator 可调用）\n3. Gate 检查（requirements / design / tasks / verification）不得绕过\n4. Sub-agent 不得调度其他 agent，只有 Orchestrator 可以\n5. Sub-agent 不得直接向用户提问，遇到无法决策的情况通过升级条件向 Orchestrator 报告\n\n## 标准 Feature Spec 工作流\n\n```\nintake → requirements → design → tasks → development → review → verification → completed\n```\n\n每个阶段切换需要通过对应的 quality gate。\n\n---\n\n## 参考\n\n- 完整 Shell 命令执行规范：`docs/engineering-lessons/universal/shell-command-execution.md`\n- 异步资源管理规范：`docs/engineering-lessons/universal/async-resource-lifecycle.md`\n- Kiro execute_pwsh 受控壳约束：`docs/engineering-lessons/ai-tools/kiro/execute-pwsh-constraints.md`\n\n</system-reminder>","metadata":{"preview":"import { tool } from \"@opencode-ai/plugin\"\nimport { daemon } from \"./lib/thin-client\"\n\nexport default tool({\n  description:\n    \"SpecForge 项目初始化工具：保证 .specforge/ 目录结构完整，补齐缺失的文件和目录（幂等）。\" +\n    \"每次 opencode 启动时由 sf-orchestrator 调用确认项目骨架就绪。\",\n  args: {},\n  async execute(_args, context) {\n    const result = await daemon.call(\"POST\", \"/api/v1/project/ensure\", {\n      projectPath: context.directory,\n    })\n    if (typeof result === \"string\") return result\n    return JSON.stringify(result, null, 2)\n  },\n})","truncated":false,"loaded":["D:\\code\\temp\\SpecForge\\setup\\userlevel-opencode\\AGENTS.md"]},"title":"setup\\userlevel-opencode\\tools\\sf_project_init.ts","time":{"start":1780117373857,"end":1780117373872}},"id":"prt_e7743839a0010NJcs4I6p8R5TU","sessionID":"ses_188bd27b4ffeUxS9GyZi5yUhXR","messageID":"msg_e77437129001oC7bgaeDx4qT2j"},{"type":"tool","tool":"read","callID":"call_a3329c29a22845a2ac1f3e44","state":{"status":"completed","input":{"filePath":"D:\\code\\temp\\SpecForge\\packages\\daemon-core\\src\\tools\\lib\\sf_project_init_core.ts"},"output":"<path>D:\\code\\temp\\SpecForge\\packages\\daemon-core\\src\\tools\\lib\\sf_project_init_core.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * sf_project_init 核心逻辑\n3:  *\n4:  * 基于 LAYOUT 字典（directory-layout.ts）遍历所有条目，\n5:  * 保证 .specforge/ 下的每个目录和文件都存在于磁盘上。\n6:  *\n7:  * 设计原则：\n8:  * - 幂等：存在即跳过，不存在即创建\n9:  * - system 文件：内容由 SpecForge 控制，存在但内容不一致时更新\n10:  * - user 文件：只保证存在，不覆盖用户已有内容\n11:  *\n12:  * 调用方：\n13:  * - daemon ingest/register 端点（插件注册时自动触发）\n14:  * - POST /api/v1/project/ensure 端点（agent 二次确认）\n15:  */\n16: \n17: import { mkdir, writeFile, access, readFile } from \"node:fs/promises\"\n18: import { join, extname, dirname } from \"node:path\"\n19: import * as os from \"node:os\"\n20: import { exec } from \"node:child_process\"\n21: import { promisify } from \"node:util\"\n22: import { LAYOUT, SPEC_DIR_NAME } from \"@specforge/types/directory-layout\"\n23: \n24: const execAsync = promisify(exec)\n25: \n26: // ============================================================\n27: // Types\n28: // ============================================================\n29: \n30: export interface InitEntry {\n31:   /** 相对于项目根的完整路径 */\n32:   path: string\n33:   /** 条目类型 */\n34:   type: \"dir\" | \"system_file\" | \"user_file\"\n35:   /** system 文件的骨架内容 */\n36:   content?: string\n37: }\n38: \n39: export interface InitResult {\n40:   success: boolean\n41:   created: string[]\n42:   existed: string[]\n43:   errors: string[]\n44:   /** 仍为占位的配置文件列表 */\n45:   placeholderFiles: string[]\n46: }\n47: \n48: // ============================================================\n49: // File Content Templates\n50: // ============================================================\n51: \n52: const SYSTEM_FILE_CONTENT: Record<string, (projectName: string, now: string) => string> = {\n53:   \"manifest.json\": (name, now) =>\n54:     JSON.stringify({ schema_version: \"6.0\", project_name: name, created_at: now }, null, 2) + \"\\n\",\n55: \n56:   \"config/project.json\": () =>\n57:     JSON.stringify({ schema_version: \"1.0\" }, null, 2) + \"\\n\",\n58: \n59:   \"config/risk_policy.json\": () =>\n60:     JSON.stringify({ schema_version: \"1.0\", rules: [] }, null, 2) + \"\\n\",\n61: \n62:   \"config/skill_fragments.json\": () =>\n63:     JSON.stringify({ schema_version: \"1.0\", fragments: {} }, null, 2) + \"\\n\",\n64: \n65:   \"knowledge/graph.json\": () =>\n66:     JSON.stringify({ nodes: [], edges: [] }, null, 2) + \"\\n\",\n67: \n68:   \"specs/README.md\": () => \"# Specs\\n\\nWork Item 规格文档目录。\\n\",\n69: \n70:   // .gitignore 内容是固定的\n71:   \".gitignore\": () =>\n72:     \"runtime/\\nlogs/\\nsessions/\\narchive/\\ncas/\\n\",\n73: \n74:   // dev-environment.md 由扫描生成，不作为 system 文件\n75: }\n76: \n77: /** 占位模板 */\n78: const PLACEHOLDER_CONTENT = \"> TODO: 由首次 intake 阶段填充\\n\"\n79: \n80: /** AGENTS.md 基础模板 */\n81: /**\n82:  * 需要判断是否为占位的配置文件（相对 .specforge/ 的路径）\n83:  */\n84: const PLACEHOLDER_CHECK_FILES = [\n85:   \"config/dev-environment.md\",\n86:   \"config/prod-environment.md\",\n87:   \"config/project-rules.md\",\n88: ]\n89: \n90: // ============================================================\n91: // Manifest Construction\n92: // ============================================================\n93: \n94: /**\n95:  * 从 LAYOUT 字典构造初始化清单\n96:  */\n97: function buildManifest(): InitEntry[] {\n98:   const entries: InitEntry[] = []\n99: \n100:   // 遍历 LAYOUT 顶层条目\n101:   for (const [key, value] of Object.entries(LAYOUT)) {\n102:     if (key === \"configFiles\") continue // 嵌套对象，子条目单独处理\n103: \n104:     if (typeof value === \"string\") {\n105:       const hasExt = extname(value) !== \"\"\n106:       if (hasExt) {\n107:         const entry = makeFileEntry(value)\n108:         if (entry) entries.push(entry)\n109:       } else {\n110:         entries.push({ path: join(SPEC_DIR_NAME, value), type: \"dir\" })\n111:       }\n112:     }\n113:   }\n114: \n115:   // configFiles 子条目\n116:   for (const subValue of Object.values(LAYOUT.configFiles)) {\n117:     if (typeof subValue === \"string\") {\n118:       const entry = makeFileEntry(subValue)\n119:       if (entry) entries.push(entry)\n120:     }\n121:   }\n122: \n123:   return entries\n124: }\n125: \n126: /**\n127:  * 判断一个 LAYOUT 值对应的文件类型和内容\n128:  * 返回 null 表示该文件由 daemon 运行时管理，不需要初始化时创建\n129:  */\n130: function makeFileEntry(relativePath: string): InitEntry | null {\n131:   const fullPath = join(SPEC_DIR_NAME, relativePath)\n132: \n133:   // dev-environment.md 是特殊 system 文件（扫描生成）\n134:   if (relativePath === \"config/dev-environment.md\") {\n135:     return { path: fullPath, type: \"system_file\" }\n136:   }\n137: \n138:   // 占位检查文件（除 dev-environment）→ user 文件\n139:   if (PLACEHOLDER_CHECK_FILES.includes(relativePath) && relativePath !== \"config/dev-environment.md\") {\n140:     return { path: fullPath, type: \"user_file\" }\n141:   }\n142: \n143:   // 有骨架内容的 → system 文件\n144:   if (relativePath in SYSTEM_FILE_CONTENT) {\n145:     return { path: fullPath, type: \"system_file\" }\n146:   }\n147: \n148:   // 其余文件（如 .jsonl 运行时文件）→ 跳过，由 daemon 自己管理\n149:   return null\n150: }\n151: \n152: // ============================================================\n153: // Core Logic\n154: // ============================================================\n155: \n156: /**\n157:  * 执行项目初始化\n158:  *\n159:  * @param projectRoot 项目根目录绝对路径\n160:  * @param projectName 项目名称（用于 manifest.json）\n161:  * @returns 初始化结果\n162:  */\n163: export async function ensureProjectInit(\n164:   projectRoot: string,\n165:   projectName?: string\n166: ): Promise<InitResult> {\n167:   const result: InitResult = {\n168:     success: true,\n169:     created: [],\n170:     existed: [],\n171:     errors: [],\n172:     placeholderFiles: [],\n173:   }\n174: \n175:   const name = projectName || projectRoot.split(/[/\\\\]/).pop() || \"untitled\"\n176:   const now = new Date().toISOString()\n177:   const manifest = buildManifest()\n178: \n179:   // 1. 先建所有目录\n180:   const dirs = manifest.filter(e => e.type === \"dir\")\n181:   for (const entry of dirs) {\n182:     const fullPath = join(projectRoot, entry.path)\n183:     try {\n184:       await mkdir(fullPath, { recursive: true })\n185:       // 目录总是\"存在\"的（mkdir recursive 不报错），不计入 created\n186:     } catch (err: any) {\n187:       if (err.code !== \"EEXIST\") {\n188:         result.errors.push(`${entry.path}: ${err.message}`)\n189:         result.success = false\n190:       }\n191:     }\n192:   }\n193: \n194:   // 2. 再处理文件\n195:   const files = manifest.filter(e => e.type !== \"dir\")\n196:   for (const entry of files) {\n197:     const fullPath = join(projectRoot, entry.path)\n198: \n199:     try {\n200:       await mkdir(dirname(fullPath), { recursive: true })\n201:     } catch {\n202:       // 父目录创建失败？继续尝试写文件\n203:     }\n204: \n205:     const exists = await fileExists(fullPath)\n206: \n207:     if (entry.type === \"system_file\") {\n208:       const content = await getSystemFileContent(entry, name, now)\n209: \n210:       if (exists) {\n211:         // 文件存在 → 比较内容 → 不一致则更新\n212:         try {\n213:           const existing = await readFile(fullPath, \"utf-8\")\n214:           if (existing !== content) {\n215:             await writeFile(fullPath, content, \"utf-8\")\n216:             result.created.push(entry.path)\n217:           } else {\n218:             result.existed.push(entry.path)\n219:           }\n220:         } catch {\n221:           // 读取失败 → 尝试覆盖\n222:           await writeFile(fullPath, content, \"utf-8\")\n223:           result.created.push(entry.path)\n224:         }\n225:       } else {\n226:         await writeFile(fullPath, content, \"utf-8\")\n227:         result.created.push(entry.path)\n228:       }\n229:     } else {\n230:       // user_file：不存在就创建占位，存在就跳过\n231:       if (exists) {\n232:         result.existed.push(entry.path)\n233:       } else {\n234:         const userContent = PLACEHOLDER_CONTENT\n235:         await writeFile(fullPath, userContent, \"utf-8\")\n236:         result.created.push(entry.path)\n237:       }\n238:     }\n239: \n240:     // 检查是否仍为占位\n241:     if (PLACEHOLDER_CHECK_FILES.some(f => entry.path.endsWith(f))) {\n242:       try {\n243:         const content = await readFile(fullPath, \"utf-8\")\n244:         if (content.startsWith(\"> TODO\")) {\n245:           result.placeholderFiles.push(entry.path)\n246:         }\n247:       } catch {\n248:         result.placeholderFiles.push(entry.path)\n249:       }\n250:     }\n251:   }\n252: \n253:   return result\n254: }\n255: \n256: /**\n257:  * 获取 system 文件的内容\n258:  */\n259: async function getSystemFileContent(\n260:   entry: InitEntry,\n261:   projectNam