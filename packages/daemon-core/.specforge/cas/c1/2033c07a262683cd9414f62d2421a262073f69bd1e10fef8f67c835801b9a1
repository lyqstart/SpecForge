tions.initialDelayMs;\n133:   }\n134: \n135:   async postEvent(sessionId: string, type: string, data: unknown): Promise<PostResult> {\n136:     if (this.disposed) {\n137:       return { ok: false, dropped: true, reason: \"disposed\" };\n138:     }\n139:     if (this.degraded) {\n140:       this.printDegradedWarningOnce();\n141:       return { ok: false, dropped: true, reason: \"degraded\" };\n142:     }\n143: \n144:     let handshake = this.cachedHandshake;\n145:     if (!handshake) {\n146:       handshake = await readHandshake(this.options.handshakePath);\n147:       if (handshake) {\n148:         this.cachedHandshake = handshake;\n149:       }\n150:     }\n151: \n152:     if (!handshake) {\n153:       return this.startBackoff(sessionId, type, data);\n154:     }\n155: \n156:     const url = `${this.options.healthzUrl}:${handshake.port}`;\n157:     const success = await postEventToDaemon(url, handshake.token, sessionId, type, data);\n158: \n159:     if (success) {\n160:       this.resetBackoff();\n161:       return { ok: true, dropped: false, reason: \"success\" };\n162:     }\n163: \n164:     this.cachedHandshake = null;\n165:     return this.startBackoff(sessionId, type, data);\n166:   }\n167: \n168:   async register(projectPath: string): Promise<RegisterResponse> {\n169:     const handshake = await readHandshake(this.options.handshakePath);\n170:     if (!handshake) {\n171:       throw new Error(\"Daemon handshake not found\");\n172:     }\n173: \n174:     const url = `${this.options.healthzUrl}:${handshake.port}`;\n175:     const response = await fetch(`${url}/api/v1/ingest/register`, {\n176:       method: \"POST\",\n177:       headers: {\n178:         \"Content-Type\": \"application/json\",\n179:         Authorization: `Bearer ${handshake.token}`,\n180:       },\n181:       body: JSON.stringify({ projectPath }),\n182:       signal: AbortSignal.timeout(5000),\n183:     });\n184: \n185:     if (!response.ok) {\n186:       const errorBody = await response.text().c