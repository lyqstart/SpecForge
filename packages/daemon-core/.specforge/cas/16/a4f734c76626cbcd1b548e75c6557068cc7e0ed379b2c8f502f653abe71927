 } catch {\n108:     return false;\n109:   }\n110: }\n111: \n112: // ── ReconnectingDaemonClient ──\n113: \n114: export class ReconnectingDaemonClient implements Disposable {\n115:   private readonly options: Required<ReconnectingDaemonClientOptions>;\n116:   private disposed = false;\n117:   private degraded = false;\n118:   private degradedWarningPrinted = false;\n119:   private backoffTimer: ReturnType<typeof setTimeout> | null = null;\n120:   private currentBackoffMs: number;\n121:   private cumulativeBackoffMs = 0;\n122:   private retryCount = 0;\n123:   private pendingEvent: { sessionId: string; type: string; data: unknown } | null = null;\n124:   private cachedHandshake: HandshakeFile | null = null;\n125: \n126:   constructor(options: ReconnectingDaemonClientOptions = {}) {\n127:     this.options = {\n128:       initialDelayMs: options.initialDelayMs ?? DEFAULT_OPTIONS.initialDelayMs,\n129:       backoffFactor: options.backoffFactor ?? DEFAULT_OPTIONS.backoffFactor,\n130:       maxCumulativeBackoffMs:\n131:         options.maxCumulativeBackoffMs ?? DEFAULT_OPTIONS.maxCumulativeBackoffMs,\n132:       handshakePath: options.handshakePath ?? DEFAULT_OPTIONS.handshakePath,\n133:       healthzUrl: options.healthzUrl ?? DEFAULT_OPTIONS.healthzUrl,\n134:     };\n135:     this.currentBackoffMs = this.options.initialDelayMs;\n136:   }\n137: \n138:   async postEvent(sessionId: string, type: string, data: unknown): Promise<PostResult> {\n139:     if (this.disposed) {\n140:       return { ok: false, dropped: true, reason: \"disposed\" };\n141:     }\n142:     if (this.degraded) {\n143:       this.printDegradedWarningOnce();\n144:       return { ok: false, dropped: true, reason: \"degraded\" };\n145:     }\n146: \n147:     let handshake = this.cachedHandshake;\n148:     if (!handshake) {\n149:       handshake = await readHandshake(this.options.handshakePath);\n150:       if (handshake) {\n151:         this.cachedHandshake = handshake;\n152:       }\n153:     }\n154: \n155