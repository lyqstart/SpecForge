matData(result));\n173:     } else {\n174:       console.log(modeSwitch.formatSuccess(result.message));\n175:     }\n176:   } catch (err) {\n177:     const cliError = toCliError(err);\n178:     console.error(modeSwitch.formatError(cliError));\n179:     process.exit(1);\n180:   }\n181: }\n182: \n183: /**\n184:  * Add daemon commands to yargs parser\n185:  */\n186: export function addDaemonCommands(yargsInstance: Argv): Argv {\n187:   return yargsInstance.command(\n188:     'daemon',\n189:     'Manage the SpecForge daemon',\n190:     (yargsInstance: Argv) => {\n191:       return yargsInstance\n192:         .command(\n193:           'start',\n194:           'Start the daemon',\n195:           (yargsInstance: Argv) => {\n196:             return yargsInstance\n197:               .option('foreground', {\n198:                 type: 'boolean',\n199:                 describe: 'Run in foreground (default: true)',\n200:                 alias: 'f',\n201:                 default: true,\n202:               })\n203:               .option('bind', {\n204:                 type: 'string',\n205:                 describe: 'Bind address',\n206:                 default: '127.0.0.1',\n207:               });\n208:           },\n209:           (argv: Arguments) => {\n210:             const modeSwitch = new ModeSwitch(argv);\n211:             commandStart(argv as any, modeSwitch);\n212:           }\n213:         )\n214:         .command(\n215:           'stop',\n216:           'Stop the daemon',\n217:           () => {},\n218:           async (argv: Arguments) => {\n219:             const modeSwitch = new ModeSwitch(argv);\n220:             await commandStop(argv, modeSwitch);\n221:           }\n222:         )\n223:         .command(\n224:           'status',\n225:           'Check daemon status',\n226:           () => {},\n227:           async (argv: Arguments) => {\n228:             const modeSwitch = new ModeSwitch(argv);\n229:             await commandStatus(argv, modeSwitch);\n230:      