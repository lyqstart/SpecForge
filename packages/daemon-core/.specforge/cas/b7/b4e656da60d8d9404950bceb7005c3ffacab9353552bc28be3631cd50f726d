: \n45: /**\n46:  * Event serialization constants\n47:  */\n48: const EVENT_SCHEMA_VERSION = '1.0';\n49: \n50: /**\n51:  * Event Logger with WAL semantics\n52:  * \n53:  * Ensures crash-safe event persistence:\n54:  * 1. Write event to events.jsonl\n55:  * 2. Fsync to ensure data is on disk\n56:  * 3. Only then allow state.json updates\n57:  * \n58:  * Multi-project support:\n59:  * - Each project has its own index file in project-indices/\n60:  * - Project indices track event counts, timestamps, and event IDs\n61:  * - Queries can filter by projectId or query across all projects\n62:  */\n63: export class EventLogger implements IEventLogger {\n64:   private basePath: string;\n65:   private eventsPath: string;\n66:   private statePath: string;\n67:   private projectIndexDir: string;\n68:   private lastEventId: string | null = null;\n69:   private eventCount = 0;\n70:   /** Map of projectId -> ProjectIndex for in-memory caching */\n71:   private projectIndices: Map<string, ProjectIndex> = new Map();\n72: \n73:   /**\n74:    * Create a new EventLogger instance\n75:    * @param basePath Base directory for event storage (default: ./data/observability)\n76:    */\n77:   constructor(basePath: string = './data/observability') {\n78:     this.basePath = basePath;\n79:     this.eventsPath = join(basePath, EVENTS_FILE);\n80:     this.statePath = join(basePath, STATE_FILE);\n81:     this.projectIndexDir = join(basePath, PROJECT_INDEX_DIR);\n82:   }\n83: \n84:   /**\n85:    * Get the project index file path for a given projectId\n86:    */\n87:   private getProjectIndexPath(projectId: string): string {\n88:     return join(this.projectIndexDir, `${projectId}.json`);\n89:   }\n90: \n91:   /**\n92:    * Initialize the Event Logger storage directory\n93:    */\n94:   async initialize(): Promise<void> {\n95:     await fs.mkdir(this.basePath, { recursive: true });\n96:     await fs.mkdir(this.projectIndexDir, { recursive: true });\n97:     \n98:     // Initialize events.jsonl if it 