tId;\n538:   }\n539: \n540:   /**\n541:    * Get the event count\n542:    * \n543:    * @returns Total number of events in the WAL\n544:    */\n545:   getEventCount(): number {\n546:     return this.eventCount;\n547:   }\n548: \n549:   /**\n550:    * Get the events file path\n551:    */\n552:   getEventsPath(): string {\n553:     return this.eventsPath;\n554:   }\n555: \n556:   /**\n557:    * Get the state file path\n558:    */\n559:   getStatePath(): string {\n560:     return this.statePath;\n561:   }\n562: \n563:   /**\n564:    * Serialize an event to JSON string\n565:    * Implements Property 8: Serialization Round-trip\n566:    * \n567:    * @param event Event to serialize\n568:    * @returns JSON string\n569:    */\n570:   static serialize(event: Event): string {\n571:     return JSON.stringify(event);\n572:   }\n573: \n574:   /**\n575:    * Deserialize a JSON string to an event\n576:    * Implements Property 8: Serialization Round-trip\n577:    * \n578:    * @param json JSON string to deserialize\n579:    * @returns Event object\n580:    */\n581:   static deserialize(json: string): Event {\n582:     return JSON.parse(json) as Event;\n583:   }\n584: \n585:   /**\n586:    * Verify serialization round-trip for an event\n587:    * Implements Property 8: parse(serialize(x)) == x\n588:    * \n589:    * @param event Event to verify\n590:    * @returns true if round-trip is successful\n591:    */\n592:   static verifySerializationRoundTrip(event: Event): boolean {\n593:     const serialized = EventLogger.serialize(event);\n594:     const deserialized = EventLogger.deserialize(serialized);\n595:     \n596:     return (\n597:       deserialized.eventId === event.eventId &&\n598:       deserialized.ts === event.ts &&\n599:       deserialized.monotonicSeq === event.monotonicSeq &&\n600:       deserialized.projectId === event.projectId &&\n601:       deserialized.category === event.category &&\n602:       deserialized.action === event.action &&\n603:       JSON.stringify(deserialized.payload) === JSON.stringify(event.payload)\n604:     );\n605:   }\n606: \n607:   /**\n608:    * Clear all events (for testing)\n609:    */\n610:   async clear(): Promise<void> {\n611:     await fs.writeFile(this.eventsPath, '', 'utf8');\n612:     await fs.writeFile(this.statePath, JSON.stringify({ schema_version: EVENT_SCHEMA_VERSION, events: [], lastEventId: null, eventCount: 0 }), 'utf8');\n613:     this.lastEventId = null;\n614:     this.eventCount = 0;\n615:     \n616:     // Clear project indices\n617:     try {\n618:       await fs.access(this.projectIndexDir);\n619:       const files = await fs.readdir(this.projectIndexDir);\n620:       for (const file of files) {\n621:         if (file.endsWith('.json')) {\n622:           await fs.unlink(join(this.projectIndexDir, file));\n623:         }\n624:       }\n625:     } catch {\n626:       // Directory doesn't exist, nothing to clear\n627:     }\n628:     this.projectIndices.clear();\n629:   }\n630: \n631:   /**\n632:    * Get WAL statistics\n633:    */\n634:   async getStats(): Promise<{\n635:     eventCount: number;\n636:     lastEventId: string | null;\n637:     fileSize: number;\n638:   }> {\n639:     let fileSize = 0;\n640:     try {\n641:       const stat = await fs.stat(this.eventsPath);\n642:       fileSize = stat.size;\n643:     } catch {\n644:       fileSize = 0;\n645:     }\n646: \n647:     return {\n648:       eventCount: this.eventCount,\n649:       lastEventId: this.lastEventId,\n650:       fileSize,\n651:     };\n652:   }\n653: }\n654: \n655: /**\n656:  * Create an EventLogger instance\n657:  * \n658:  * @param basePath Optional base path for storage\n659:  * @returns Configured EventLogger instance\n660:  */\n661: export function createEventLogger(basePath?: string): EventLogger {\n662:   return new EventLogger(basePath);\n663: }\n\n(End of file - total 663 lines)\n</content>","metadata":{"preview":"/**\n * Event Logger module\n * \n * Implements WAL (Write-Ahead Log) semantics:\n * 1. E