 Daemon startup process; after startup completes, the\n16:  * Daemon must not automatically initiate session state reconstruction via WAL replay.\n17:  */\n18: \n19: import * as fs from 'fs/promises';\n20: import * as path from 'path';\n21: import { v7 as uuidv7 } from 'uuid';\n22: import { Event, ProjectState, ConsistencyCheckResult, ConsistencyIssue, RepairResult } from '../types';\n23: import { WAL } from '../wal';\n24: import { StateManager } from '../state/StateManager';\n25: import { IPathResolver } from '../daemon/path-resolver';\n26: import { SessionRegistry } from '../session/SessionRegistry';\n27: \n28: export interface SessionReconnectResult {\n29:   success: boolean;\n30:   sessionId: string;\n31:   reconnected: boolean;\n32:   reason?: string;\n33: }\n34: \n35: export class RecoverySubsystem {\n36:   private pathResolver: IPathResolver;\n37:   private projectPath: string;\n38:   private eventsPath: string;\n39:   private statePath: string;\n40:   private schemaVersion: string = '1.0';\n41:   \n42:   private _isReady: boolean = false;\n43: \n44:   // Property 21: Track startup phase to limit WAL replay session reconstruction\n45:   private isInStartupPhase: boolean = false;\n46:   private hasStartupCompleted: boolean = false;\n47: \n48:   private wal: WAL | null = null;\n49:   private stateManager: StateManager | null = null;\n50:   private sessionRegistry?: SessionRegistry;\n51: \n52:   constructor(pathResolver: IPathResolver, projectPath: string, wal?: WAL, stateManager?: StateManager, sessionRegistry?: SessionRegistry) {\n53:     this.pathResolver = pathResolver;\n54:     this.projectPath = projectPath;\n55:     this.wal = wal ?? null;\n56:     this.stateManager = stateManager ?? null;\n57:     this.sessionRegistry = sessionRegistry;\n58:     this.eventsPath = this.pathResolver.resolveEventsPath(projectPath);\n59:     this.statePath = this.pathResolver.resolveStatePath(projectPath);\n60:   }\n61: \n62:   /**\n63:    * Get events path\n64:    */\n65:   getEventsPath(): string {\n66:     return this.eventsPath;\n67:   }\n68: \n69:   /**\n70:    * Get state path\n71:    */\n72:   getStatePath(): string {\n73:     return this.statePath;\n74:   }\n75: \n76:   /**\n77:    * Check consistency and repair if needed\n78:    * Property 20: Validates that repair produces consistent state\n79:    * \n80:    * Uses WAL to read events, StateManager.rebuildState() to rebuild,\n81:    * then verifies consistency between events and the rebuilt state.\n82:    */\n83:   async checkAndRepair(): Promise<ConsistencyCheckResult> {\n84:     const { events } = this.wal\n85:       ? await this.wal.readAllEvents()\n86:       : { events: await this.loadEvents() };\n87: \n88:     let rebuiltState: ProjectState;\n89: \n90:     if (this.stateManager) {\n91:       rebuiltState = await this.stateManager.rebuildState();\n92:     } else {\n93:       rebuiltState = await this.rebuildFromEvents(events);\n94:     }\n95: \n96:     // Session replay from WAL events\n97:     if (this.sessionRegistry) {\n98:       const sessionEvents = events.filter(e =>\n99:         e.category === 'session' ||\n100:         (!e.category && e.action?.startsWith('session.'))\n101:       );\n102:       if (sessionEvents.length > 0) {\n103:         const summary = await this.sessionRegistry.startupReplay(sessionEvents);\n104:         console.log(`[RecoverySubsystem] Session replay: ${summary.replayedCount} events replayed, ${summary.restoredBindings} bindings restored, ${summary.restoredAliases} aliases restored`);\n105:       }\n106:     }\n107: \n108:     const issues: ConsistencyIssue[] = [];\n109: \n110:     if (events.length > 0) {\n111:       const lastEvent = events[events.length - 1]!;\n112:       if (rebuiltState.lastEventId !== lastEvent.eventId) {\n113:         issues.push({\n114:           type: 'state_mismatch',\n115:           description: `State lastEventId (${rebuiltState.lastEventId}) does not match last event (${lastEvent.eventId})`,\n116:           affectedEventId: lastEvent.eventId,\n117:           affectedProjectPath: this.projectPath,\n118:         });\n119:       }\n120: \n121:       for (let i = 1; i < events.length; i++) {\n122:         const prevEvent = events[i - 1]!;\n123:         const currEvent = events[i]!;\n124:         if (currEvent.ts < prevEvent.ts) {\n125:           issues.push({\n126:             type: 'out_of_order',\n127:             description: `Event at index ${i} has timestamp before previous event`,\n128:             affectedEventId: currEvent.eventId,\n129:             affectedProjectPath: this.projectPath,\n130:           });\n131:         }\n132:       }\n133: \n134:       const eventIds = new Set(events.map(e => e.eventId));\n135:       if (rebuiltState.lastEventId && !eventIds.has(rebuiltState.lastEventId)) {\n136:         issues.push({\n137:           type: 'missing_event',\n138:           description: `State references event ${rebuiltState.lastEventId} that doesn't exist in events`,\n139:           affectedEventId: rebuiltState.lastEventId,\n140:           affectedProjectPath: this.projectPath,\n141:         });\n142:       }\n143:     }\n144: \n145:     const result: ConsistencyCheckResult = {\n146:       isValid: issues.length === 0,\n147:       issues,\n148:     };\n149: \n150:     if (!result.isValid) {\n151:       await this.repairInconsistency(result);\n152:     }\n153: \n154:     return result;\n155:   }\n156: \n157:   /**\n158:    * Check consistency between events.jsonl and state.json\n159:    * \n160:    * Consistency rules:\n161:    * 1. state.json lastEventId must match the last event in events.jsonl\n162:    * 2. Every event in events.jsonl must have a corresponding state entry\n163:    * 3. Events must be in chronological order (monotonic ts)\n164:    */\n165:   async checkConsistency(): Promise<ConsistencyCheckResult> {\n166:     const issues: ConsistencyIssue[] = [];\n167:     \n168:     try {\n169:       // Check if events.jsonl exists\n170:       await fs.access(this.eventsPath);\n171:       \n172:       // Check if state.json exists\n173:       await fs.access(this.statePath);\n174:       \n175:       // Load events\n176:       const events = await this.loadEvents();\n177:       \n178:       // Load state\n179:       const state = await this.loadState();\n180:       \n181:       // Check 1: State mismatch - state.json lastEventId should match last event\n182:       if (events.length > 0) {\n183:         const lastEvent = events[events.length - 1]!;\n184:         if (state.lastEventId !== lastEvent.eventId) {\n185:           issues.push({\n186:             type: 'state_mismatch',\n187:             description: `State lastEventId (${state.lastEventId}) does not match last event (${lastEvent.eventId})`,\n188:             affectedEventId: lastEvent.eventId,\n189:             affectedProjectPath: this.projectPath,\n190:           });\n191:         }\n192:         \n193:         // Check 3: Event ordering - ts must be monotonic\n194:         for (let i = 1; i < events.length; i++) {\n195:           const prevEvent = events[i - 1]!;\n196:           const currEvent = events[i]!;\n197:           if (currEvent.ts < prevEvent.ts) {\n198:             issues.push({\n199:               type: 'out_of_order',\n200:               description: `Event at index ${i} has timestamp before previous event`,\n201:               affectedEventId: currEvent.eventId,\n202:               affectedProjectPath: this.projectPath,\n203:             });\n204:           }\n205:         }\n206:       }\n207:       \n208:       // Check 2: Events without state - check for orphaned events\n209:       const eventIds = new Set(events.map(e => e.eventId));\n210:       if (state.lastEventId && !eventIds.has(state.lastEventId)) {\n211:         issues.push({\n212:           type: 'missing_event',\n213:           description: `State references event ${state.lastEventId} that doesn't exist in events.jsonl`,\n214:           affectedEventId: state.lastEventId,\n215:           affectedProjectPath: this.projectPath,\n216:         });\n217:       }\n218:       \n219:     } catch (error) {\n220:       // File doesn't exist, this is OK for initial startup\n221:     }\n222: \n223:     return {\n224:       isValid: issues.length === 0,\n225:       issues,\n226:     };\n227:   }\n228: \n229:   /**\n230:    * Repair inconsistency according to predefined repair rules\n231:    * \n232:    * Repair rules:\n233:    * 1. state_mismatch: Rebuild state from events.jsonl\n234:    * 2. missing_event: Remove stale state reference\n235:    * 3. out_of_order: Reorder events and rebuild state\n236:    * \n237:    * CRITICAL: This method does NOT append repair events to events.jsonl.\n238:    * This ensures that after repair: rebuild(events) == s' holds.\n239:    * The repairEvents in the result are for audit/logging purposes only.\n240:    */\n241:   async repairInconsistency(result: ConsistencyCheckResult): Promise<RepairResult> {\n242:     const repairEvents: Event[] = [];\n243:     \n244:     const { events } = this.wal\n245:       ? await this.wal.readAllEvents()\n246:       : { events: await this.loadEvents() };\n247: \n248:     let repairedState: ProjectState;\n249: \n250:     for (const issue of result.issues) {\n251:       const repairEvent = await this.applyRepairRule(issue, events);\n252:       if (repairEvent) {\n253:         repairEvents.push(repairEvent);\n254:       }\n255:     }\n256: \n257:     if (this.stateManager) {\n258:       repairedState = await this.stateManager.rebuildState();\n259:     } else {\n260:       repairedState = await this.rebuildFromEvents(events);\n261:     }\n262: \n263:     await this.writeState(repairedState);\n264: \n265:     return {\n266:       success: true,\n267:       repairedState,\n268:       repairEvents,\n269:     };\n270:   }\n271: \n272:   /**\n273:    * Apply a specific repair rule based on issue type\n274:    */\n275:   private async applyRepairRule(issue: ConsistencyIssue, events: Event[]): Promise<Event | null> {\n276:     switch (issue.type) {\n277:       case 'state_mismatch':\n278:         // Rebuild state from events - this is the authoritative repair\n279:         return this.createRepairEvent('state_mismatch', `Rebuilt state from ${events.length} events`);\n280:         \n281:       case 'missing_event':\n282:         // Remove stale state reference by rebuilding from valid events\n283:         return this.createRepairEvent('missing_event', `Removed stale reference to ${issue.affectedEventId}`);\n284:         \n285:       case 'out_of_order':\n286:         // Events will be reordered during rebuild\n287:         return this.createRepairEvent('out_of_order', `Fixed event ordering issue`);\n288:         \n289:       default:\n290:         return null;\n291:     }\n292:   }\n293: \n294:   /**\n295:    * Create a repair event\n296:    */\n297:   private createRepairEvent(issueType: string, description: string): Event {\n298:     return {\n299:       eventId: uuidv7(),\n300:       ts: Date.now(),\n301:       projectId: this.projectPath,\n302:       action: 'recovery.repaired',\n303:       payload: {\n304:         issueType,\n305:         description,\n306:       },\n307:       metadata: {\n308:         schemaVersion: this.schemaVersion,\n309:         source: 'daemon',\n310:       },\n311:     };\n312:   }\n313: \n314:   /**\n315:    * Rebuild state from events (authoritative source of truth)\n316:    * This is the core of Property 20 - after repair, rebuild(events) == s'\n317:    */\n318:   async rebuildFromEvents(events: Event[]): Promise<ProjectState> {\n319:     if (!events || events.length === 0) {\n320:       return this.createEmptyState();\n321:     }\n322: \n323:     // Sort events by timestamp to ensure correct order\n324:     const sortedEvents = [...events].sort((a, b) => a.ts - b.ts);\n325:     \n326:     const lastEvent = sortedEvents[sortedEvents.length - 1]!;\n327:     \n328:     return {\n329:       projectPath: this.projectPath,\n330:       schemaVersion: this.schemaVersion,\n331:       activeSessions: [],\n332:       workItems: [],\n333:       lastEventId: lastEvent.eventId,\n334:       lastEventTs: lastEvent.ts,\n335:     };\n336:   }\n337: \n338:   /**\n339:    * Create empty state\n340:    */\n341:   private createEmptyState(): ProjectState {\n342:     return {\n343:       projectPath: this.projectPath,\n344:       schemaVersion: this.schemaVersion,\n345:       activeSessions: [],\n346:       workItems: [],\n347:       lastEventId: '',\n348:       lastEventTs: 0,\n349:     };\n350:   }\n351: \n352:   /**\n353:    * Attempt session WAL replay reconstruction (only during startup - Property 21)\n354:    * \n355:    * Property 21: WAL replay session reconstruction may only occur within Daemon startup process.\n356:    * After startup completes, the Daemon must not automatically initiate session state reconstruction via WAL replay.\n357:    * \n358:    * @param sessionId Session ID to reconnect\n359:    * @returns true if reconnection was attempted and succeeded\n360:    */\n361:   async attemptSessionReconnect(sessionId: string): Promise<boolean> {\n362:     // Property 21: Only attempt WAL replay during startup phase\n363:     if (!this.isInStartupPhase || this.hasStartupCompleted) {\n364:       // Post-startup session detection doesn't trigger reconnection\n365:       return false;\n366:     }\n367:     \n368:     // Attempt to reconnect - in real implementation, this would check if \n369:     // the OpenCode process is still alive via some mechanism\n370:     const result = await this.performSessionReconnect(sessionId);\n371:     return result.reconnected;\n372:   }\n373: \n374:   /**\n375:    * Perform the actual session reconnection logic\n376:    * In a real implementation, this would communicate with the OpenCode process\n377:    */\n378:   private async performSessionReconnect(sessionId: string): Promise<SessionReconnectResult> {\n379:     // Load events to find session information\n380:     const events = await this.loadEvents();\n381:     \n382:     // Find the session activation event\n383:     const activationEvent = events.find(\n384:       e => e.action === 'session.activated' && e.payload && \n385:            (e.payload as any).sessionId === sessionId\n386:     );\n387:     \n388:     if (!activationEvent) {\n389:       return {\n390:         success: false,\n391:         sessionId,\n392:         reconnected: false,\n393:         reason: 'No activation event found for session',\n394:       };\n395:     }\n396:     \n397:     // In real implementation, we'd check if the OpenCode process is still alive\n398:     // For now, simulate successful reconnection during startup\n399:     return {\n400:       success: true,\n401:       sessionId,\n402:       reconnected: true,\n403:       reason: 'Session reconnected during startup',\n404:     };\n405:   }\n406: \n407:   /**\n408:    * Start the startup phase for session reconnection\n409:    * Called by Daemon at the beginning of startup\n410:    */\n411:   beginStartupPhase(): void {\n412:     this._isReady = false;\n413:     this.isInStartupPhase = true;\n414:     this.hasStartupCompleted = false;\n415:   }\n416: \n417:   /**\n418:    * End the startup phase - no more reconnection attempts allowed\n419:    * Called by Daemon after startup is complete\n420:    */\n421:   completeStartup(): void {\n422:     this.hasStartupCompleted = true;\n423:     this.isInStartupPhase = false;\n424:     this._isReady = true;\n425:   }\n426: \n427:   isReady(): boolean {\n428:     return this._isReady;\n429:   }\n430: \n431:   /**\n432:    * Check if we're currently in the startup phase\n433:    * Used for testing and verification\n434:    */\n435:   isStartupPhase(): boolean {\n436:     return this.isInStartupPhase;\n437:   }\n438: \n439:   /**\n440:    * Check if startup has completed\n441:    * Used for testing and verification\n442:    */\n443:   hasCompletedStartup(): boolean {\n444:     return this.hasStartupCompleted;\n