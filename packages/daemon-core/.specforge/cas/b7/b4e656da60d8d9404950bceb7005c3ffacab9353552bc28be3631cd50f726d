:     };\n350: \n351:     const workItemId = payload?.work_item_id ?? event.projectId;\n352:     if (!workItemId) return;\n353: \n354:     const toState = payload?.to_state ?? '';\n355:     if (!toState) return;\n356: \n357:     const workflowType = payload?.workflow_type ?? DEFAULT_WORKFLOW_TYPE;\n358:     const now = event.ts ?? Date.now();\n359:     const existing = this.workItemStates.get(workItemId);\n360: \n361:     if (existing) {\n362:       // Update existing Work Item\n363:       this.workItemStates.set(workItemId, {\n364:         work_item_id: workItemId,\n365:         workflow_type: existing.workflow_type,\n366:         current_state: toState,\n367:         created_at: existing.created_at,\n368:         updated_at: now,\n369:       });\n370:     } else {\n371:       // Create new Work Item\n372:       this.workItemStates.set(workItemId, {\n373:         work_item_id: workItemId,\n374:         workflow_type: workflowType,\n375:         current_state: toState,\n376:         created_at: now,\n377:         updated_at: now,\n378:       });\n379:     }\n380:   }\n381: \n382:   /**\n383:    * Check if a state name is in the valid workflow states list.\n384:    */\n385:   private isValidStateName(state: string): boolean {\n386:     return VALID_STATES.includes(state);\n387:   }\n388: \n389:   /**\n390:    * Build a ProjectState from the in-memory work item states.\n391:    */\n392:   private buildProjectState(): ProjectState {\n393:     const workItems = Array.from(this.workItemStates.values());\n394: \n395:     return {\n396:       projectPath: this.projectPath,\n397:       schemaVersion: '1.0',\n398:       activeSessions: [],\n399:       workItems,\n400:       lastEventId: this._lastEventId,\n401:       lastEventTs: this._lastEventTs,\n402:     };\n403:   }\n404: \n405:   /**\n406:    * Persist the current in-memory state to state.json.\n407:    * Always called AFTER WAL fsync to maintain ordering invariant.\n408:    */\n409:   private async persistState(): Pro