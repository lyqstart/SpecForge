:       eventLogger: this.eventLogger,\n105:       sessionRegistry: this.sessionRegistry,\n106:       projectManager: this.projectManager,\n107:       recoverySubsystem: this.recoverySubsystem,\n108:       toolDispatcher: new ToolDispatcher({\n109:         stateManager: this.stateManager,\n110:         workflowEngine: this.workflowEngine,\n111:         projectManager: this.projectManager,\n112:         eventLogger: this.eventLogger,\n113:         eventBus: this.eventBus,\n114:         permissionEngine: this.permissionEngine,\n115:         cas: undefined,\n116:         sessionRegistry: this.sessionRegistry,\n117:       }),\n118:     });\n119: \n120:     // Initialize GracefulShutdownHandler\n121:     // Requirements 3.1, 3.2, 3.3, 3.4, 3.5: Integration with GracefulShutdownHandler\n122:     this.gracefulShutdownHandler = createGracefulShutdownHandler({\n123:       autoAttach: false, // We'll attach manually after startup\n124:     });\n125:   }\n126: \n127:   async start(): Promise<void> {\n128:     if (this.isRunning) {\n129:       throw new Error('Daemon is already running');\n130:     }\n131: \n132:     // Property 21: Begin startup phase for session reconnection\n133:     this.recoverySubsystem.beginStartupPhase();\n134: \n135:     // 1. Enforce single instance\n136:     await this.handshakeManager.enforceSingleInstance();\n137: \n138:     // 2. Start HTTP server\n139:     const { port } = await this.httpServer.start();\n140: \n141:     // 3. Generate token and write handshake file\n142:     const token = this.handshakeManager.generateToken();\n143:     await this.handshakeManager.writeHandshake(process.pid, port, token);\n144:     \n145:     // 4. Set token in HTTP server for auth\n146:     this.httpServer.setToken(token);\n147: \n148:     // 5. Initialize components\n149:     // Detect and handle legacy nested paths before StateManager initialize\n150:     await this.detectAndHandleLegacyState(this.config.getRuntimeDir());\n151:     await this.stateManager.init