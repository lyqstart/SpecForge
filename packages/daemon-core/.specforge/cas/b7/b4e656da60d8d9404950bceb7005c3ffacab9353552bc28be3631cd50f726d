n344:     }\n345:   }\n346: \n347:   /**\n348:    * Validate event has all required fields\n349:    */\n350:   private validateEvent(event: Event): void {\n351:     if (!event.eventId) {\n352:       throw new Error('Event must have eventId');\n353:     }\n354:     if (!event.ts) {\n355:       throw new Error('Event must have ts (timestamp)');\n356:     }\n357:     if (!event.projectId) {\n358:       throw new Error('Event must have projectId');\n359:     }\n360:     if (!event.category) {\n361:       throw new Error('Event must have category');\n362:     }\n363:     if (!event.action) {\n364:       throw new Error('Event must have action');\n365:     }\n366:   }\n367: \n368:   /**\n369:    * Get events from the WAL with optional filtering\n370:    * \n371:    * @param filter Optional filter criteria\n372:    * @yield Events matching the filter\n373:    */\n374:   async *getEvents(filter?: EventFilter): AsyncIterable<Event> {\n375:     try {\n376:       const stat = await fs.stat(this.eventsPath);\n377:       if (stat.size === 0) {\n378:         return;\n379:       }\n380:     } catch {\n381:       return;\n382:     }\n383: \n384:     const stream = createReadStream(this.eventsPath, { encoding: 'utf8' });\n385:     const rl = createInterface({ input: stream, crlfDelay: Infinity });\n386:     let count = 0;\n387:     const limit = filter?.limit ?? Infinity;\n388: \n389:     for await (const line of rl) {\n390:       if (!line.trim()) continue;\n391:       \n392:       try {\n393:         const event = JSON.parse(line) as Event;\n394:         \n395:         // Apply filter\n396:         if (this.matchesFilter(event, filter)) {\n397:           yield event;\n398:           count++;\n399:           \n400:           if (count >= limit) {\n401:             break;\n402:           }\n403:         }\n404:       } catch {\n405:         // Skip invalid lines\n406:         continue;\n407:       }\n408:     }\n409:   }\n410: \n411:   /**\n412:    * Check if an event matches the fi