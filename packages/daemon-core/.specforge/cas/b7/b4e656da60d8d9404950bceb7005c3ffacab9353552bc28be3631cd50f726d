n69:   async initialize(): Promise<void> {\n70:     // Step 1: Initialize WAL\n71:     await this.wal.initialize();\n72:     \n73:     // Step 2: Ensure state directory exists\n74:     await fs.mkdir(path.dirname(this.statePath), { recursive: true });\n75: \n76:     // Step 3: Rebuild in-memory state from WAL (authoritative source)\n77:     await this.rebuildState();\n78: \n79:     // Step 4: Persist rebuilt in-memory state to state.json\n80:     await this.persistState();\n81:   }\n82: \n83:   // ═══════════════════════════════════════════════════\n84:   //  Transition\n85:   // ═══════════════════════════════════════════════════\n86: \n87:   /**\n88:    * Perform a state transition for a Work Item.\n89:    * \n90:    * Steps:\n91:    *   1. Validate transition is legal (from_state matches current state)\n92:    *   2. Validate state names are in the valid workflow states list\n93:    *   3. Create a 'state.transition' event via WAL\n94:    *   4. Append event to WAL (with fsync)\n95:    *   5. Update in-memory state\n96:    *   6. Persist checkpoint to state.json\n97:    * \n98:    * Optimistic locking: if `fromState` does not match the current state\n99:    * of the Work Item, the transition is rejected with an error.\n100:    * \n101:    * @param workItemId  - The Work Item to transition (e.g. 'WI-001')\n102:    * @param fromState   - Expected current state ('' for new Work Items)\n103:    * @param toState     - Target state\n104:    * @param actor       - Actor performing the transition\n105:    * @param workflowType - Workflow type (default 'feature_spec')\n106:    * @param extraPayload - Additional payload fields\n107:    * @throws Error if the transition is invalid\n108:    */\n109:   async transition(\n110:     workItemId: string,\n111:     fromState: string,\n112:     toState: string,\n113:     actor: string = 'system',\n114:     workflowType: string = DEFAULT_WORKFLOW_TYPE,\n115:     extraPayload: Record<string, unknown> = {},\n116:   ): Promise<void> {\n117:     // ── Step 1: Validate state names ──\n118:     if (!this.isValidStateName(toState)) {\n119:       throw new Error(\n120:         `Invalid target state \"${toState}\". Valid states: ${VALID_STATES.join(', ')}`,\n121:       );\n122:     }\n123: \n124:     if (fromState !== '' && !this.isValidStateName(fromState)) {\n125:       throw new Error(\n126:         `Invalid from_state \"${fromState}\". Valid states: ${VALID_STATES.join(', ')}`,\n127:       );\n128:     }\n129: \n130:     // ── Step 2: Optimistic lock — verify from_state matches current state ──\n131:     const current = this.workItemStates.get(workItemId);\n132:     const currentState = current?.current_state ?? '';\n133: \n134:     if (fromState !== currentState) {\n135:       throw new Error(\n136:         `Optimistic lock failed: expected from_state=\"${fromState}\" ` +\n137:         `but current state for \"${workItemId}\" is \"${currentState}\"`,\n138:       );\n139:     }\n140: \n141:     // ── Step 3: Create the state.transition event ──\n142:     const event = this.wal.createEvent(\n143:       workItemId,\n144:       'state',\n145:       'state.transition',\n146:       {\n147:         work_item_id: workItemId,\n148:         from_state: fromState,\n149:         to_state: toState,\n150:         workflow_type: workflowType,\n151:         transitioned_at: Date.now(),\n152:         ...extraPayload,\n153:       },\n154:       actor,\n155:     );\n156: \n157:     // ── Step 4: Append event to WAL (with fsync guarantee) ──\n158:     await this.wal.appendEvent(event);\n159: \n160:     // ── Step 5: Update in-memory state ──\n161:     this.applyStateTransition(event);\n162: \n163:     // ── Step 6: Persist checkpoint ──\n164:     await this.persistState();\n165:   }\n166: \n167:   // ═══════════════════════════════════════════════════\n168:   //  State queries\n169:   // ═══════════════════════════════════════════════════\n170: \n171:   /**\n172:    * Get the current state for a Work Item.\n173:    * Returns null if the Work Item does not exist.\n174:    */\n175:   getState(workItemId: string): WorkItemState | null {\n176:     return this.workItemStates.get(workItemId) ?? null;\n177:   }\n178: \n179:   async getAllStates(): Promise<Record<string, WorkItemState>> {\n180:     const result: Record<string, WorkItemState> = {};\n181:     for (const [key, value] of this.workItemStates) {\n182:       result[key] = value;\n183:     }\n184:     return result;\n185:   }\n186: \n187:   /**\n188:    * List all known Work Items with their current states.\n189:    * Returns a copy (not a reference) so callers cannot mutate internal state.\n190:    */\n191:   listWorkItems(): WorkItemState[] {\n192:     return Array.from(this.workItemStates.values());\n193:   }\n194: \n195:   /**\n196:    * Get the internal WAL instance.\n197:    * Used by Daemon.ts to eliminate a separate private wal field,\n198:    * ensuring a single WAL instance via StateManager.\n199:    */\n200:   getWal(): WAL {\n201:     return this.wal;\n202:   }\n203: \n204:   // ═══════════════════════════════════════════════════\n205:   //  Rebuild\n206:   // ═══════════════════════════════════════════════════\n207: \n208:   /**\n209:    * Rebuild the in-memory state by replaying all WAL events.\n210:    * \n211:    * This is the authoritative reconstruction: the WAL is the single\n212:    * source of truth. The ProjectState is derived from events, never\n213:    * edited directly.\n214:    * \n215:    * After rebuild, state.json is updated to match.\n216:    */\n217:   async rebuildState(): Promise<ProjectState> {\n218:     const { events } = await this.wal.readAllEvents();\n219:     \n220:     // Clear and rebuild\n221:     this.workItemStates.clear();\n222: \n223:     let lastEventId = '';\n224:     let lastEventTs = 0;\n225: \n226:     for (const event of events) {\n227:       if (!event || !event.eventId) continue;\n228: \n229:       lastEventId = event.eventId;\n230:       lastEventTs = event.ts ?? 0;\n231: \n232:       if (event.action === 'state.transition') {\n233:         this.applyStateTransition(event);\n234:       }\n235:     }\n236: \n237:     // Persist last event tracking for getCurrentState()\n238:     this._lastEventId = lastEventId;\n239:     this._lastEventTs = lastEventTs;\n240: \n241:     const state: ProjectState = {\n242:       projectPath: this.projectPath,\n243:       schemaVersion: '1.0',\n244:       activeSessions: [],\n245:       workItems: Array.from(this.workItemStates.values()),\n246:       lastEventId,\n247:       lastEventTs,\n248:     };\n249: \n250:     return state;\n251:   }\n252: \n253:   /**\n254:    * Rebuild state from WAL events and persist to state.json.\n255:    * Convenience wrapper around rebuildState() + persistState().\n256:    */\n257:   async rebuildFromEventsFile(): Promise<void> {\n258:     await this.rebuildState();\n259:     await this.persistState();\n260:   }\n261: \n262:   // ═══════════════════════════════════════════════════\n263:   //  Legacy API (kept for backward compat)\n264:   // ═══════════════════════════════════════════════════\n265: \n266:   /**\n267:    * Append an event and persist state.json checkpoint.\n268:    * \n269:    * WAL ordering: events.jsonl is fsynced BEFORE state.json is written.\n270:    * This guarantees that on crash recovery, the WAL is always ahead of state.json.\n271:    * \n272:    * @deprecated Use transition() for state changes.\n273:    */\n274:   async appendEvent(event: Event): Promise<void> {\n275:     // Step 1: Append event to WAL (events.jsonl) with fsync\n276:     await this.wal.appendEvent(event);\n277:     \n278:     // Step 2: Track last event info for all events\n279:     this._lastEventId = event.eventId;\n280:     this._lastEventTs = event.ts ?? Date.now();\n281: \n282:     // Step 3: Apply event to in-memory state\n283:     if (event.action === 'state.transition') {\n284:       this.applyStateTransition(event);\n285:     }\n286: \n287:     // Step 4: Persist state.json