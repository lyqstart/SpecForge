\myapp\n183:   config_dir: \"[TODO-FILL]\"       # 配置文件目录\n184:                                   # 例：/etc/myapp / /opt/myapp/config\n185:   log_dir: \"[TODO-FILL]\"          # 日志目录\n186:                                   # 例：/var/log/myapp\n187:   temp_dir: null                  # 临时文件目录（null 表示用系统默认）\n188:   data_dir: null                  # 数据目录（如有持久化数据）\n189: ```\n190: \n191: ---\n192: \n193: ### 资源限制\n194: \n195: ```yaml\n196: resource_limits:\n197:   # 为什么要配：executor 写代码时不能假设无限资源\n198:   # 例如：不能无限制地开线程、不能假设内存够大\n199: \n200:   max_memory_mb: null             # 内存上限（容器/JVM 等）\n201:                                   # 例：512 / 2048 / null（无限制）\n202:   max_cpu_cores: null             # CPU 核数上限\n203:   max_file_handles: null          # 文件句柄上限（Linux ulimit）\n204:   run_as_root: false              # 是否以 root 运行\n205:                                   # 为什么要配：非 root 时某些操作需要 sudo 或权限调整\n206:   container_runtime: docker       # 容器运行时（如适用）\n207:                                   # 可选：docker / containerd / podman / null\n208: ```\n209: \n210: ---\n211: \n212: ### CI/CD\n213: \n214: ```yaml\n215: cicd:\n216:   platform: github-actions        # CI 平台\n217:                                   # 可选：github-actions / gitlab-ci / jenkins /\n218:                                   #        azure-devops / circleci / none\n219:   trigger: push-to-main           # 触发条件\n220:                                   # 例：push-to-main / tag / manual / pr\n221:   test_command: \"[TODO-FILL]\"     # CI 中跑测试的命令\n222:                                   # 例：bun test / pytest / mvn test\n223:   deploy_command: \"[TODO-FILL]\"   # 部署命令\n224:                                   # 例：./scripts/deploy.sh / kubectl apply -f k8s/\n225:   rollback_command: null          # 回滚命令（如有）\n226:   restart_command: \"[TODO-FILL]\"  # 重启服务命令\n227:                                   # 例：systemctl restart myapp / docker restart myapp\n228: ```\n229: \n230: ---\n231: \n232: ### 观测（日志/指标/追踪）\n233: \n234: ```yaml\n235: observability:\n236:   log_framework: \"[TODO-FILL]\"    # 日志框架\n237:                                   # 例：winston / pino / logback / zap / slog\n238:                                   # 为什么要配：executor 写日志代码时用这个框架\n239: \n240:   log_format: json                # 日志格式\n241:                                   # 可选：json（推荐，便于机器解析）/ text\n242:                                   # 为什么要配：json 格式便于 ELK/Loki 等收集\n243: \n244:   log_level: info                 # 生产日志级别\n245:                                   # 可选：debug / info / warn / error\n246:                                   # 为什么要配：debug 级别在生产会产生大量日志\n247: \n248:   metrics_system: null            # 指标系统（如有）\n249:                                   # 例：prometheus / datadog / cloudwatch / null\n250: \n251:   tracing_system: null            # 分布式追踪（如有）\n252:                                   # 例：jaeger / zipkin / opentelemetry / null\n253: ```\n254: \n255: ---\n256: \n257: ### 安全\n258: \n259: ```yaml\n260: security:\n261:   credential_management: env-vars # 凭证管理方式\n262:                                   # 可选：\n263:                                   #   env-vars      环境变量（最简单）\n264:                                   #   vault         HashiCorp Vault\n265:                                   #   aws-secrets   AWS Secrets Manager\n266:                                   #   azure-keyvault Azure Key Vault\n267:                                   #   k8s-secrets   Kubernetes Secrets\n268:                                   # 为什么要配：executor 写凭证读取代码时用这个方式\n269: \n270:   tls_required: true              # 是否强制 TLS（HTTPS）\n271:   auth_method: null               # 认证方式（如有）\n272:                                   # 例：jwt / oauth2 / session / api-key / null\n273: ```\n274: \n275: ---\n276: \n277: ### 部署要求（未来 scan-prod-environment 对账用）\n278: \n279: ```yaml\n280: deploy_requirements:\n281:   # 这一段定义\"部署前必须满足的条件\"\n282:   # 未来 scan-prod-environment.ts 会扫描生产环境，与这里对账\n283:   # 不满足则阻断部署\n284: \n285:   min_disk_free_gb: 5             # 部署前最少可用磁盘 GB\n286:   m