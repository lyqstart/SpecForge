R_NAME}/logs/error.log`\n94: \n95: /**\n96:  * 将错误信息写入 Error_Log（specforge/logs/error.log）\n97:  * 写入失败时静默，不抛出异常 — 日志写入失败不应影响调用方\n98:  */\n99: export async function logErrorToFile(\n100:   baseDir: string,\n101:   component: string,\n102:   event: string,\n103:   error: unknown\n104: ): Promise<void> {\n105:   try {\n106:     const errorLogPath = join(baseDir, ERROR_LOG_RELATIVE_PATH)\n107:     // Ensure directory exists\n108:     const dir = join(baseDir, SPEC_DIR_NAME, \"logs\")\n109:     await mkdir(dir, { recursive: true })\n110:     // Write error entry\n111:     await appendJsonl(errorLogPath, {\n112:       timestamp: new Date().toISOString(),\n113:       level: \"ERROR\",\n114:       component,\n115:       event,\n116:       message: error instanceof Error ? error.message : String(error),\n117:     })\n118:   } catch {\n119:     // Silently swallow — log write failure must not affect caller\n120:   }\n121: }\n122: \n123: // ============================================================\n124: // Dynamic Import: Compatibility Check\n125: // ============================================================\n126: \n127: /**\n128:  * Dynamically import and execute checkCompatibilityAtEntry.\n129:  * On import or execution failure, logs the error and silently continues.\n130:  * Never throws — safe to call at the start of any tool core function.\n131:  */\n132: export async function tryCheckCompatibility(\n133:   baseDir: string,\n134:   component: string\n135: ): Promise<void> {\n136:   try {\n137:     const mod = await import(\"../../../scripts/lib/compatibility\")\n138:     if (mod && typeof mod.checkCompatibilityAtEntry === \"function\") {\n139:       mod.checkCompatibilityAtEntry(baseDir)\n140:     }\n141:   } catch (err) {\n142:     // Import or execution failed — log and silently continue\n143:     await logErrorToFile(baseDir, component, \"dynamic_import_failed\", err)\n144:   }\n145: }\n\n(End of file - total 145 lines)\n</content>","metadata":{"preview":"/**\n *