e` 标记主要使用的那个\n20: \n21: ---\n22: \n23: ## 使用说明\n24: \n25: ```yaml\n26: # 多个开发环境示例\n27: environments:\n28:   - label: \"本地笔记本\"\n29:     primary: true\n30:     host_type: local-windows\n31:     # ... 其他字段\n32: \n33:   - label: \"AWS 云开发机\"\n34:     primary: false\n35:     host_type: cloud-aws\n36:     # ... 其他字段\n37: ```\n38: \n39: ---\n40: \n41: ## 配置项\n42: \n43: ### 基本身份\n44: \n45: ```yaml\n46: environments:\n47:   - label: \"主开发环境\"          # 给这个环境起个名字，方便区分\n48:     primary: true                 # 是否是主要使用的开发环境\n49: \n50:     host_type: local-windows      # 这台机器的类型\n51:                                   # 可选值：\n52:                                   #   local-windows   本地 Windows 电脑\n53:                                   #   local-mac       本地 Mac 电脑\n54:                                   #   local-linux     本地 Linux 电脑\n55:                                   #   wsl2            Windows 下的 WSL2\n56:                                   #   docker-desktop  Docker Desktop 容器\n57:                                   #   vm              虚拟机（VMware/VirtualBox）\n58:                                   #   cloud-aws       AWS EC2 / Cloud9\n59:                                   #   cloud-azure     Azure VM / Dev Box\n60:                                   #   cloud-gcp       GCP Cloud Shell / VM\n61:                                   #   remote-ssh      通过 SSH 连接的远程服务器\n62:                                   # 为什么要配：不同类型的机器路径分隔符、\n63:                                   # 换行符、权限模型不同，Agent 需要知道\n64: \n65:     hostname: \"[TODO-FILL]\"       # 机器名（scan 自动填）\n66: ```\n67: \n68: ---\n69: \n70: ### 操作系统\n71: \n72: ```yaml\n73:     os:\n74:       platform: win32             # 平台标识（scan 自动填）\n75:                                   # 可选：win32 / darwin / linux\n76:       version: \"[TODO-FILL]\"      # 人类可读版本（scan 自动填）\n77:                                   # 例：Windows 11 Pro 24H2 / macOS 14.5 / Ubuntu 22.04\n78:       arch: x64                   # CPU 架构（scan 自动填）\n79:                                   # 可选：x64 / arm64 / ia32\n80:       totalmem_gb: 16             # 总内存 GB（scan 自动填）\n81:       cpu_count: 8                # 逻辑 CPU 核数（scan 自动填）\n82:       disk_free_gb: \"[TODO-FILL]\" # 可用磁盘 GB（scan 自动填，如未填请手动写）\n83: ```\n84: \n85: ---\n86: \n87: ### 语言运行时\n88: \n89: ```yaml\n90:     runtimes:\n91:       # 只填你实际安装的语言，没有的删掉这一行\n92:       # 为什么要配：executor 在跑测试时必须用正确版本；\n93:       #             design 在选库时要确认版本兼容性\n94: \n95:       python: \"3.10.12\"           # python --version（scan 自动填）\n96:       python3: \"3.10.12\"          # python3 --version（scan 自动填）\n97:       node: \"20.11.0\"             # node --version（scan 自动填）\n98:       bun: \"1.1.0\"                # bun --version（scan 自动填）\n99:       java: \"[TODO-FILL]\"         # java -version（scan 暂不支持，手动填）\n100:                                   # 例：17.0.9 / 21.0.1\n101:       dotnet: \"[TODO-FILL]\"       # dotnet --version（scan 暂不支持，手动填）\n102:       go: \"[TODO-FILL]\"           # go version（scan 自动填，如已安装）\n103:       rust: \"[TODO-FILL]\"         # rustc --version（scan 自动填，如已安装）\n104:       php: \"[TODO-FILL]\"          # php --version（scan 暂不支持，手动填）\n105:       ruby: \"[TODO-FILL]\"         # ruby --version（scan 暂不支持，手动填）\n106: ```\n107: \n108: ---\n109: \n110: ### 包管理器\n111: \n112: ```yaml\n113:     package_managers:\n114:       # 只填你实际使用的，没有的删掉\n115:       # 为什么要配：executor 在添加依赖时必须用正确的包管理器命令\n116: \n117:       npm: \"10.2.4\"               # npm --version（scan 自动填）\n118:       pnpm: \"[TODO-FILL]\"         # pnpm --version（scan 自动填，如已安装）\n119:       yarn: \"[TODO-FILL]\"         # yarn --version（scan 自动填，如已安装）\n120:       bun: \"1.1.0\"                # bun --version（scan 自动填）\n121:       pip: \"[TODO-FILL]\"          # pip --version（scan 暂不支持，手动填）\n122:       poetry: \"[TODO-FILL]\"       # poetry --version（手动填）\n123:       maven: \"[TODO-FILL]\"        # mvn -v（手动填）\n124:       gradle: \"[TODO-FILL]\"       # gradle -v（手动填）\n125:       cargo: \"[TODO-FILL]\"        # cargo --version（scan 自动填，如已安装）\n126:       go_mod: true                # 是否使用 go mod（手动填 true/false）\n127: ```\n128: \n129: ---\n130: \n131: ### Shell\n132: \n133: ```yaml\n134:     shell:\n135:       preferred: pwsh             # 首选 shell（scan 自动填）\n136:                                   # 可选：pwsh / powershell / cmd / bash / zsh / sh\n137:                                   # 为什么要配：verification_command 必须用这个 shell 跑\n138:       encoding: UTF-8             # 控制台编码（scan 自动填）\n139:                                   # 为什么要配：中文/特殊字符输出乱码的根源\n140:       path_separator: \"\\\\\"        # 路径分隔符（scan 自动填）\n141:                                   # Windows: \"\\\\\"  Linux/Mac: \"/\"\n142: ```\n143: \n144: ---\n145: \n146: ### 本地化（语言与时区）\n147: \n148: ```yaml\n149:     locale:\n150:       # ⚠️ 重要：以下两个值是\"代码和文档的语言基准\"\n151:       # 所有代码注释、文档、日志消息的语言必须与 system_lang 一致\n152:       # 所有日期时间值必须使用 tz_name 对应的时区\n153: \n154:       system_lang: zh-CN          # 系统语言（scan 自动填）\n155:                                   # 例：zh-CN / en-US / ja-JP\n156:                                   # 为什么要配：Agent 生成的注释和文档语言由此决定\n157: \n158:       tz_name: Asia/Shanghai      # IANA 时区名（scan 自动填）\n159:                                   # 例：Asia/Shanghai / America/New_York / Europe/London\n160:                                   # 为什么要配：日志时间戳、定时任务、日期计算的基准\n161: \n162:       tz_offset_minutes: 480      # UTC 偏移分钟数（scan 自动填）\n163:                                   # UTC+8 = 480 / UTC-5 = -300\n164: \n165:       date_format: ISO-8601       # 日期格式偏好\n166:                                   # 推荐：ISO-8601（2024-01-15）\n167:                                   # 其他：YYYY/MM/DD / MM/DD/YYYY\n168: ```\n169: \n170: ---\n171: \n172: ### 网络\n173: \n174: ```yaml\n175:     network:\n176:       has_internet: true          # 是否有外网访问\n177:                                   # 为什么要配：无外网时 executor 必须用内网镜像源\n178: \n179:       proxy: null                 # HTTP 代理（如有）\n180:                                   # 例：http://proxy.company.com:8080\n181:                                   # 没有填 null\n182: \n183:       pip_index_url: null         # Python 包镜像源\n184:                                   # 例：https://pypi.tuna.tsinghua.edu.cn/simple\n185:                                   # 没有填 null（使用官方源）\n186: \n187:       npm_registry: null          # npm 镜像源\n188:                                   # 例：https://registry.npmmirror.com\n189:                                   # 没有填 null（使用官方源）\n190: \n191:       maven_mirror: null          # Maven 镜像源（Java 项目）\n192:                                   # 例：https://maven.aliyun.com/repository/public\n193:                                   # 没有填 null\n194: ```\n195: \n196: ---\n197: \n198: ### 工具\n199: \n200: ```yaml\n201:     tools:\n202:       # scan 自动填，以下是常见工具示例\n203:       # 为什么要配：verifier 在跑检查命令时需要知道哪些工具可用\n204: \n205:       git: { available: true, version: \"2.45.0\" }\n206:       docker: { available: true, version: \"24.0.5\" }\n207:       rg: { available: false }    # ripgrep，不可用时 verifier 改用 grep\n208:       jq: { available: true, version: \"1.7\" }\n209:       curl: { available: true, version: \"8.4.0\" }\n210: ```\n211: \n212: ---\n213: \n214: ### 远程访问（如 host_type 是 remote-ssh / cloud-*）\n215: \n216: ```yaml\n217:     remote_access:\n218:       # 如果这个开发环境是远程的，填这里；本地机器填 null\n219: \n220:       ssh_command: null           # SSH 连接命令\n221:                                   # 例：ssh dev@192.168.1.100\n222:                                   # 本地机器填 null\n223: \n224:       ssh_key_path: null          # SSH 私钥路径（如需要）\n225:                                   # 例：~/.ssh/id_rsa\n226: \n227:       jump_host: null             # 跳板机（如需要）\n228:                                   # 例：ssh -J jump@bastion.company.com dev@target\n229: \n230:       vpn_required: false         # 是否需要 VPN 才能访问\n231: ```\n232: \n233: ---\n234: \n235: ## 常见问题\n236: \n237: **Q：scan 自动填了，我还需要检查吗？**\n238: A：需要。scan 只能探测已安装的工具，无法知道你的网络情况、镜像源配置、\n239:    是否需要 VPN 等。标有 `[TODO-FILL]` 的字段必须手动填。\n240: \n241: **Q：我有两台电脑，怎么同步这份配置？**\n242: A：把这份文件提交到 git。每台电脑 pull 后，SpecForge 会自动比对扫描结果\n243:    与文件内容，提示你确认差异。\n244: \n245: **Q：system_lang 和 tz_name 影响什么？**\n246: A：所有 Agent 生成的代码注释、文档、日志消息都会用 system_lang 的语言；\n247:    所有日期时间相关的代码都会用 tz_name 的时区。这两个值一旦确定，\n248:    整个项目的代码风格就固定了。\n249: \n250: **Q：修改这份文件后会怎样？**\n251: A：下次 SpecForge 启动时，orchestrator 会检测到变化，提示相关 Agent\n252:    重新评估受影响的决策（主要是 sf-design 和 sf-executor）。\n\n(End of file - total 252 lines)\n</content>","metadata":{"preview":"# 开发环境配置\n\n<!-- 这是什么 -->\n这份文件描述你的开发环境事实。SpecForge 的所有 Agent 在生成代码、选择命令、\n做架构决策时，都会读取这里的值。**代码和文档中不得硬编码这里出现的任何值**——\n必须引用这里的字段。\n\n<!-- 谁在什么时候用 -->\n- **sf-orchestrator**：初始化时自动扫描并填充，之后每次启动时与扫描结果比对\n- **sf-design**：选择技术方案时参考运行时版本和资源限制\n- **sf-executor**：执行命令时选择正确的 shell 和工具路径\n- **sf-verifier**：兼容性测试时按此版本跑\n\n<!-- 怎么用 -->\n1. 首次使用 SpecForge 时，`scan-host-profile.ts` 会自动扫描并填充大部分字段\n2. 扫描完成后，SpecForge 会展示结果让你确认\n3. 扫描无法获取的字段（标有 `[TODO-FILL]`）需要你手动填写\n4. 如果你有多个开发环境（笔记本 + 云服务器），在 `environments` 数组中添加多条，\n   用 `primary: true` 标记主要使用的那个\n","truncated":false,"loaded":[]},"title":"setup\\userlevel-templates\\dev-environment.md","time":{"start":1780102177799,"end":1780102177838}},"id":"prt_e765ba3fc001HpaddrNw4fZ7vj","sessionID":"ses_189bddf2affernl5sk4Mbk66Uk","messageID":"msg_e765b9222001IjWJZOgxt48Iix"},{"type":"tool","tool":"read","callID":"call_83d6391496d84a87ab2cb24e","state":{"status":"completed","input":{"filePath":"D:\\code\\temp\\SpecForge\\setup\\userlevel-templates\\prod-environment.md"},"output":"<path>D:\\code\\temp\\SpecForge\\setup\\userlevel-templates\\prod-environment.md</path>\n<type>file</type>\n<content>\n1: # 生产环境配置\n2: \n3: <!-- 这是什么 -->\n4: 这份文件描述你的生产环境事实和部署要求。它有两个用途：\n5: 1. **设计参考**：sf-design 在做架构决策时，必须保证设计在生产环境能跑通\n6: 2. **部署 Gate**：未来的 `scan-prod-environment.ts` 会扫描真实生产环境，\n7:    与这份文件对账——不满足则阻断部署\n8: \n9: <!-- 谁在什么时候用 -->\n10: - **sf-design**：架构设计时参考生产约束（版本/资源/网络）\n11: - **sf-task-planner**：verification_command 必须能在生产最低版本通过\n12: - **sf-verifier**：L9 兼容性测试按生产版本跑\n13: - **sf-debugger**：排查问题时知道去哪里看日志、怎么登录\n14: \n15: <!-- 怎么用 -->\n16: 1. 在 intake 阶段，orchestrator 会引导你填写这份文件\n17: 2. 只填与你项目相关的字段，不相关的字段删掉或填 null\n18: 3. 标有 `[TODO-FILL]` 的字段是必填项\n19: 4. 标有 `[SCAN-FUTURE]` 的字段未来会由扫描器自动填，现在手动填\n20: \n21: ---\n22: \n23: ## 配置项\n24: \n25: ### 基本身份\n26: \n27: ```yaml\n28: deployment_target: docker         # 部署目标类型\n29:                                   # 可选值：\n30:                                   #   bare-metal      物理服务器或普通云 VM\n31:                                   #   docker          Docker 容器（单机）\n32:                                   #   docker-compose  Docker Compose 多容器\n33:                                   #   k8s             Kubernetes\n34:                                   #   serverless-aws  AWS Lambda\n35:                                   #   serverless-gcp  GCP Cloud Functions\n36:                                   #   serverless-azure Azure Functions\n37:                                   #   desktop-app     桌面应用（Electron/Qt/WPF）\n38:                                   #   mobile-ios      iOS App\n39:                                   #   mobile-android  Android App\n40:                                   # 为什么要配：部署方式决定了打包格式、\n41:                                   # 配置注入方式、日志收集方式\n42: \n43: environment_name: production      # 环境名称\n44:                                   # 例：production / staging / uat\n45: ```\n46: \n47: ---\n48: \n49: ### 操作系统（生产服务器）\n50: \n51: ```yaml\n52: os:\n53:   platform: linux                 # 生产服务器平台\n54:                                   # 可选：linux / windows / darwin（少见）\n55:   distro: \"[TODO-FILL]\"           # Linux 发行版（如适用）\n56:                                   # 例：Ubuntu 22.04 / CentOS 7 / Alpine 3.18\n57:   arch: x64                       # CPU 架构\n58:                                   # 可选：x64 / arm64\n59:   totalmem_gb: \"[TODO-FILL]\"      # 生产服务器内存 GB [SCAN-FUTURE]\n60:   cpu_count: \"[TODO-FILL]\"        # 生产服务器 CPU 核数 [SCAN-FUTURE]\n61:   disk_free_gb: \"[TODO-FILL]\"     # 可用磁盘 GB [SCAN-FUTURE]\n62: ```\n63: \n64: ---\n65: \n66: ### 语言运行时（生产最低版本）\n67: \n68: ```yaml\n69: runtimes:\n70:   # ⚠️ 重要：这里填的是生产环境的最低版本\n71:   # executor 写的代码必须在这个版本通过编译/lint\n72:   # verifier 的 L9 兼容性测试必须在这个版本跑通\n73: \n74:   # 只填项目实际使用的语言，其他删掉\n75:   python_min: \"3.8\"               # 生产 Python 最低版本\n76:                                   # 为什么要配：Python 3.9+ 有 walrus 等新语法，\n77:                                   # 如果生产是 3.8，这些语法会报错\n78:   node_min: \"18.0.0\"              # 生产 Node.js 最低版本\n79:   java_min: \"11\"                  # 生产 Java 最低版本（LTS 版本号）\n80:   dotnet_min: \"6.0\"               # 生产 .NET 最低版本\n81:   go_min: \"1.21\"                  # 生产 Go 最低版本\n82: ```\n83: \n84: ---\n85: \n86: ### 本地化（生产环境）\n87: \n88: ```yaml\n89: locale:\n90:   # ⚠️ 重要：生产环境的时区可能与开发环境不同\n91:   # 所有日期时间处理必须显式指定时区，不能依赖系统默认\n92: \n93:   tz_name: UTC                    # 生产服务器时区\n94:                                   # 推荐：UTC（避免夏令时问题）\n95:                                   # 如果业务强依赖本地时间：Asia/Shanghai 等\n96:                                   # 为什么要配：日志时间戳、定时任务的基准\n97: \n98:   system_lang: en-US              # 生产服务器系统语言\n99:                                   # 通常是 en-US（Linux 服务器默认）\n100:                                   # 为什么要配：影响错误消息语言、日期格式解析\n101: ```\n102: \n103: ---\n104: \n105: ### 网络与访问\n106: \n107: ```yaml\n108: network:\n109:   has_internet: true              # 生产服务器是否有外网访问\n110:                                   # 为什么要配：无外网时代码不能调用外部 API，\n111:                                   # 依赖包必须走内网镜像\n112: \n113:   internal_only: false            # 是否仅内网访问（不对外暴露）\n114: \n115:   pip_index_url: null             # 生产环境 Python 包镜像源\n116:   npm_registry: null              # 生产环境 npm 镜像源\n117:   maven_mirror: null              # 生产环境 Maven 镜像源\n118: \n119:   # 服务器访问信息（sf-debugger 排查问题时需要）\n120:   ssh_command: \"[TODO-FILL]\"      # SSH 连接命令\n121:                                   # 例：ssh ops@prod-01.company.com\n122:                                   # 无 SSH 访问填 null\n123: \n124:   ssh_key_path: null              # SSH 私钥路径（如需要）\n125:   jump