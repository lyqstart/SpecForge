bject.entries(configFiles)) {\n64:       expect(typeof value, `LAYOUT.configFiles.${key} should be a string`).toBe('string');\n65:     }\n66:   });\n67: \n68:   it('all USER_LAYOUT values should be strings', () => {\n69:     for (const [key, value] of Object.entries(USER_LAYOUT)) {\n70:       expect(typeof value, `USER_LAYOUT.${key} should be a string`).toBe('string');\n71:     }\n72:   });\n73: \n74:   it('LAYOUT path values should not start with \"/\" (relative paths)', () => {\n75:     for (const [key, value] of Object.entries(LAYOUT)) {\n76:       if (key === 'configFiles') continue;\n77:       const v = value as string;\n78:       expect(v.startsWith('/'), `LAYOUT.${key}=\"${v}\" should not start with /`).toBe(false);\n79:     }\n80:   });\n81: \n82:   it('LAYOUT.configFiles path values should not start with \"/\" (relative paths)', () => {\n83:     const configFiles = LAYOUT.configFiles as Record<string, string>;\n84:     for (const [key, value] of Object.entries(configFiles)) {\n85:       expect(value.startsWith('/'), `LAYOUT.configFiles.${key}=\"${value}\" should not start with /`).toBe(false);\n86:     }\n87:   });\n88: \n89:   it('USER_LAYOUT path values should not start with \"/\" (relative paths)', () => {\n90:     for (const [key, value] of Object.entries(USER_LAYOUT)) {\n91:       const v = value as string;\n92:       expect(v.startsWith('/'), `USER_LAYOUT.${key}=\"${v}\" should not start with /`).toBe(false);\n93:     }\n94:   });\n95: });\n96: \n97: // ---------------------------------------------------------------------------\n98: // Suite 2: Path construction function validation\n99: // ---------------------------------------------------------------------------\n100: \n101: describe('Suite 2: Path construction functions', () => {\n102:   it('resolveProjectPath(\"/proj\", \"runtime\") returns correct path', () => {\n103:     const result = resolveProjectPath('/proj', 'runtime');\n104:     expect(np(result)).toBe(np('/proj/.specforge/runtime'));\n105