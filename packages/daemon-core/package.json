{
  "name": "@specforge/daemon-core",
  "version": "1.0.0",
  "description": "Daemon Core module for SpecForge V6 - Central process and Single Source of Truth",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "specforge",
    "daemon",
    "v6"
  ],
  "author": "SpecForge Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vitest/coverage-v8": "^3.0.7",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "fast-check": "^4.8.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  },
  "dependencies": {
    "@specforge/permission-engine": "workspace:*",
    "@specforge/scope-gate": "workspace:*",
    "@specforge/opencode-adapter": "workspace:*",
    "@specforge/workflow-runtime": "workspace:*",
    "@specforge/observability": "workspace:*",
    "@specforge/plugin-loader": "workspace:*",
    "@specforge/types": "workspace:*",
    "@specforge/host-profile": "workspace:*",
    "uuid": "^11.1.0"
  },
  "schema_version": "1.0"
}
