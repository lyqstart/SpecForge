{
  "name": "@specforge/permission-engine",
  "version": "0.1.0",
  "description": "Permission Engine module for SpecForge V6 - Fine-grained access control and authorization",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rimraf dist",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:property": "vitest run tests/property/",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "dev": "concurrently \"bun run build:watch\" \"bun run test:watch\""
  },
  "keywords": [
    "specforge",
    "permission",
    "authorization",
    "access-control",
    "v6",
    "architecture"
  ],
  "author": "SpecForge Team",
  "license": "MIT",
  "dependencies": {
    "@specforge/daemon-core": "workspace:*",
    "@specforge/types": "workspace:*",
    "yaml": "^2.9.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "concurrently": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.0.0",
    "fast-check": "^3.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/specforge/specforge.git",
    "directory": "permission-engine"
  },
  "bugs": {
    "url": "https://github.com/specforge/specforge/issues"
  },
  "homepage": "https://github.com/specforge/specforge#readme"
}